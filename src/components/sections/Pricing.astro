---
import { PRICING_PLANS } from '../../data/pricing';
---
<section id="abonnement" style="position:relative;padding:7rem 0;background:var(--bg);overflow:hidden;">

  <div class="orb" style="width:600px;height:400px;background:radial-gradient(ellipse,rgba(232,25,44,0.07) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);"></div>
  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>

  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1;">

    <!-- Header -->
    <div style="text-align:center;margin-bottom:4.5rem;" class="fade-in-up">
      <span class="section-label lbl-red">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Tarifs 2026
      </span>
      <!-- Urgency badge -->
      <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 16px;background:rgba(255,193,7,0.1);border:1px solid rgba(255,193,7,0.3);border-radius:20px;margin-bottom:1rem;margin-top:0.75rem;">
        <span style="width:7px;height:7px;background:#FFC107;border-radius:50%;animation:pulse-red 1.5s ease-in-out infinite;flex-shrink:0;"></span>
        <span style="font-family:'Outfit',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.08em;color:#FFC107;">🔥 Offre Coupe du Monde — Prix spécial jusqu'au 19 juillet 2026</span>
      </div>
      <h2 style="font-family:'Outfit',sans-serif;font-size:clamp(2.2rem,4vw,3.5rem);font-weight:800;color:#fff;margin-top:0.75rem;margin-bottom:1rem;line-height:1.1;">
        Choisissez votre <span style="color:var(--accent);">formule</span>
      </h2>
      <p style="font-family:'Barlow',sans-serif;font-size:1rem;color:var(--text-muted);max-width:500px;margin:0 auto;line-height:1.8;">
        Sans engagement. <strong style="color:#fff;">Remboursement 30 jours garanti.</strong> Livraison instantanée.
      </p>
    </div>

    <!-- Pricing cards — filmbox "Choose your plan" style -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;align-items:start;max-width:960px;margin:0 auto;" class="pricing-grid fade-in-up">
      {PRICING_PLANS.map((plan, i) => (
        <div
          style={`
            background: var(--bg-card);
            border: 1px solid ${plan.popular ? 'var(--border-accent)' : 'var(--border)'};
            border-radius: 18px;
            padding: ${plan.popular ? '2.75rem 2rem' : '2.25rem 1.75rem'};
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            ${plan.popular ? 'transform: translateY(-12px); box-shadow: 0 0 80px rgba(232,25,44,0.12), 0 40px 80px rgba(0,0,0,0.4);' : ''}
          `}
        >
          <!-- Popular indicator -->
          {plan.popular && (
            <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);background:var(--accent);color:white;font-family:'Outfit',sans-serif;font-weight:700;font-size:0.65rem;letter-spacing:0.1em;padding:5px 22px;border-radius:0 0 12px 12px;white-space:nowrap;text-transform:uppercase;">
              ★ Le Plus Populaire
            </div>
          )}

          {plan.popular && (
            <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(232,25,44,0.05) 0%,transparent 60%);pointer-events:none;border-radius:18px;"></div>
          )}

          <!-- Plan name -->
          <div style={`margin-bottom:1.5rem;${plan.popular ? 'margin-top:1.5rem;' : ''}`}>
            <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.1rem;color:#fff;margin-bottom:0.25rem;">{plan.name}</div>
            <div style="font-family:'Barlow',sans-serif;font-size:0.82rem;color:var(--text-muted);">{plan.screens} connexion{plan.screens > 1 ? 's' : ''} simultanée{plan.screens > 1 ? 's' : ''}</div>
          </div>

          <!-- Price — filmbox style with red color -->
          <div style="margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border);">
            <div style="display:flex;align-items:flex-start;gap:2px;margin-bottom:4px;">
              <span style={`font-family:'Outfit',sans-serif;font-weight:300;font-size:1.25rem;color:${plan.popular ? 'var(--accent)' : 'var(--text-muted)'};margin-top:4px;`}>€</span>
              <span style={`font-family:'Outfit',sans-serif;font-weight:900;font-size:3.75rem;line-height:1;color:${plan.popular ? 'var(--accent)' : '#fff'};letter-spacing:-0.03em;`}>{plan.price}</span>
            </div>
            <div style="font-family:'Barlow',sans-serif;font-size:0.82rem;color:var(--text-muted);">
              par {plan.period} — soit {(plan.price / 12).toFixed(2).replace('.', ',')} €/mois
            </div>
          </div>

          <!-- Features list -->
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.85rem;margin-bottom:2rem;flex:1;">
            {plan.features.map((feature: string) => (
              <li style="display:flex;align-items:flex-start;gap:10px;font-family:'Barlow',sans-serif;font-size:0.87rem;color:var(--text-muted);line-height:1.55;">
                <span style={`color:${plan.popular ? 'var(--accent)' : 'var(--green)'};font-size:0.9rem;flex-shrink:0;margin-top:1px;`}>●</span>
                {feature}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={`https://wa.me/33XXXXXXXXX?text=Bonjour%2C+je+souhaite+commander+la+${encodeURIComponent(plan.name)}+Atlas+Pro+ONTV`}
            target="_blank"
            rel="noopener"
            style={`
              display: flex;
              align-items: center;
              justify-content: center;
              gap: 8px;
              padding: 14px;
              border-radius: 10px;
              font-family: 'Outfit', sans-serif;
              font-weight: 700;
              font-size: 0.875rem;
              text-decoration: none;
              letter-spacing: 0.02em;
              transition: all 0.25s ease;
              ${plan.popular
                ? 'background: var(--accent); color: white; box-shadow: 0 8px 30px rgba(232,25,44,0.35);'
                : 'background: rgba(255,255,255,0.06); border: 1px solid var(--border-light); color: #fff;'
              }
            `}
            onmouseover={plan.popular
              ? "this.style.background='#FF2D40';this.style.transform='translateY(-2px)'"
              : "this.style.background='rgba(255,255,255,0.10)';this.style.borderColor='var(--border-accent)'"}
            onmouseout={plan.popular
              ? "this.style.background='var(--accent)';this.style.transform='translateY(0)'"
              : "this.style.background='rgba(255,255,255,0.06)';this.style.borderColor='var(--border-light)'"}
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.099 1.508 5.817L.057 23.887a.5.5 0 0 0 .556.556l6.07-1.451C8.362 23.658 10.118 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm5.53 17.12c-.272.767-1.571 1.462-2.147 1.524-.549.058-1.25.084-2.015-.124-.464-.13-1.059-.302-1.825-.631-3.21-1.387-5.3-4.626-5.462-4.839-.163-.214-1.329-1.768-1.329-3.374 0-1.604.839-2.392 1.137-2.718.271-.296.591-.37.789-.37.197 0 .394.002.566.01.182.008.426-.069.667.509.251.599.853 2.083.927 2.234.075.152.124.33.025.532-.099.2-.149.327-.296.503-.148.175-.311.392-.444.527-.148.148-.302.31-.13.607.173.297.769 1.268 1.651 2.053 1.133 1.011 2.089 1.325 2.386 1.473.297.148.47.124.643-.074.173-.198.74-.863 1.038-1.16.198-.198.397-.149.668.025.272.173 1.727.815 2.024.964.297.149.495.223.568.347.074.124.074.718-.198 1.485z"/></svg>
            Commander via WhatsApp
          </a>
        </div>
      ))}
    </div>

    <!-- Guarantee badges -->
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:1.5rem 3rem;margin-top:4rem;" class="fade-in-up">
      {[
        { icon:`<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, text:"Remboursement 30 jours" },
        { icon:`<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>`, text:"Livraison < 5 minutes" },
        { icon:`<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`, text:"Paiement sécurisé" },
        { icon:`<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`, text:"Support WhatsApp 24h/7j" },
      ].map(g => (
        <div style="display:flex;align-items:center;gap:9px;">
          <span style="display:flex;" set:html={g.icon} />
          <span style="font-family:'Outfit',sans-serif;font-size:0.85rem;font-weight:600;color:var(--text-muted);">{g.text}</span>
        </div>
      ))}
    </div>

    <!-- Payment methods -->
    <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:0.75rem;margin-top:2rem;" class="fade-in-up">
      <span style="font-family:'Outfit',sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-muted);margin-right:0.5rem;">Paiement accepté :</span>
      {['PayPal', 'Virement bancaire', 'Bitcoin', 'USDT', 'CreditCard'].map((m, i) => (
        <span style="padding:5px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:8px;font-family:'Outfit',sans-serif;font-size:0.72rem;font-weight:600;color:var(--text-muted);display:flex;align-items:center;gap:6px;">
          {i === 0 && <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 11C7 11 7.5 15 12 15s7-4 7-4M3 7s1.5 8 9 8 9-8 9-8"/></svg>}
          {i === 1 && <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>}
          {i === 2 && <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>}
          {i === 3 && <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>}
          {i === 4 && <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>}
          {m === 'CreditCard' ? 'Carte bancaire' : m}
        </span>
      ))}
    </div>

    <!-- Free trial banner -->
    <div style="margin-top:3.5rem;padding:2rem 2.5rem;background:rgba(232,25,44,0.06);border:1px solid rgba(232,25,44,0.2);border-radius:16px;display:flex;align-items:center;justify-content:space-between;gap:2rem;flex-wrap:wrap;" class="fade-in-up">
      <div>
        <div style="font-family:'Outfit',sans-serif;font-size:1.5rem;font-weight:800;color:#fff;margin-bottom:0.3rem;">Pas encore convaincu ?</div>
        <p style="font-family:'Barlow',sans-serif;font-size:0.9rem;color:var(--text-muted);line-height:1.6;">Essayez gratuitement pendant <strong style="color:var(--accent);">24 heures</strong> — sans carte bancaire, sans engagement.</p>
      </div>
      <a
        href="https://wa.me/33XXXXXXXXX?text=Bonjour%2C+je+voudrais+un+essai+gratuit+24h+Atlas+Pro+ONTV"
        target="_blank" rel="noopener"
        class="btn-orange"
        style="flex-shrink:0;"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.099 1.508 5.817L.057 23.887a.5.5 0 0 0 .556.556l6.07-1.451C8.362 23.658 10.118 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm5.53 17.12c-.272.767-1.571 1.462-2.147 1.524-.549.058-1.25.084-2.015-.124-.464-.13-1.059-.302-1.825-.631-3.21-1.387-5.3-4.626-5.462-4.839-.163-.214-1.329-1.768-1.329-3.374 0-1.604.839-2.392 1.137-2.718.271-.296.591-.37.789-.37.197 0 .394.002.566.01.182.008.426-.069.667.509.251.599.853 2.083.927 2.234.075.152.124.33.025.532-.099.2-.149.327-.296.503-.148.175-.311.392-.444.527-.148.148-.302.31-.13.607.173.297.769 1.268 1.651 2.053 1.133 1.011 2.089 1.325 2.386 1.473.297.148.47.124.643-.074.173-.198.74-.863 1.038-1.16.198-.198.397-.149.668.025.272.173 1.727.815 2.024.964.297.149.495.223.568.347.074.124.074.718-.198 1.485z"/></svg>
        Essai Gratuit 24h
      </a>
    </div>

  </div>

  <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
</section>

<style>
  @media (max-width: 900px) {
    .pricing-grid { grid-template-columns: 1fr !important; max-width: 420px; margin-left: auto; margin-right: auto; }
    .pricing-popular { transform: none !important; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('#abonnement .fade-in-up').forEach(el => obs.observe(el));
</script>

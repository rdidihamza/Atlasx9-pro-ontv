    </svg>`,
    color: "#f97316",
  },
  {
    name: "Smart TV Samsung & LG",
    desc: "Tizen OS, WebOS, Android TV",
    badge: null,
    badgeColor: null,
    guide: "Samsung: App Store > 'IPTV Smarters'\nLG: App Store > 'Smarters'\nAndroid TV: 'TiviMate' ou code Downloader\nRoku: Canal+ Store disponible",

---
const TMDB_IMG = "https://image.tmdb.org/t/p/w342";

const trendingMovies = [
  { title: "Projet dernière chance",    poster: "/wzyy8ZrsuHfAt4iz4iH3rT0tdoT.jpg", genre: "Sci-Fi"    },
  { title: "Peaky Blinders : L'Immortel", poster: "/xARW7zvWb3I7erpbm1Q3oyUgy79.jpg", genre: "Action"  },
  { title: "Avatar : De feu et de cendres", poster: "/5BnOt0PRymp5mXuoKv1unQ9x8I8.jpg", genre: "Sci-Fi" },
  { title: "Scream 7",                  poster: "/j6Y7vqULt8tRlXVFXHK5aj3nCo4.jpg", genre: "Horreur"   },
  { title: "Greenland : Migration",     poster: "/mu05wZK0MH2bYmuO7hXwZECqC1X.jpg", genre: "Action"    },
  { title: "Zootopie 2",               poster: "/hBI7Wrps6tDjhEzBxJgoPLhbmT1.jpg", genre: "Animation" },
  { title: "Retour à Silent Hill",      poster: "/hm4HgeeQsPgsxkPU3wxZvosI5Dh.jpg", genre: "Horreur"   },
  { title: "Send Help",                 poster: "/bMAn4qERdEfxotddEHWfMmkfjRv.jpg", genre: "Comédie"   },
  { title: "Pirouette fatale",          poster: "/xnh0rBBPKB6DyLiqek8dX1X7F7t.jpg", genre: "Thriller"  },
  { title: "L'Ultime Héritier",         poster: "/7YhgM7hjsmdCeNEebCBBYraRjyT.jpg", genre: "Thriller"  },
];

const trendingSeries = [
  { title: "Daredevil : Born Again",    poster: "/xDUoAsU8lQHOOoRkFiBuarmACDN.jpg", genre: "Action"    },
  { title: "One Piece",                 poster: "/vx8dTTbJFHxAv2QAdvLyb6GkrN6.jpg", genre: "Aventure"  },
  { title: "Invincible",                poster: "/s2cmk5aVFddnUeXHvRJMPhhShtE.jpg", genre: "Super-Héros"},
  { title: "Jujutsu Kaisen",            poster: "/w2Shg7bI5WB7LINt1KxB7eihO8s.jpg", genre: "Animé"     },
  { title: "Peaky Blinders",            poster: "/wfD5hDb61sS203D0te7JbIzeyQe.jpg", genre: "Crime"     },
  { title: "Grey's Anatomy",            poster: "/meLc14IucQOzlqRn3ERCWjt5BEC.jpg", genre: "Drame"     },
  { title: "Harry Hole",                poster: "/9Q1juw9ihqoqgLmvwtGDeQLWCsa.jpg", genre: "Policier"  },
  { title: "Frieren",                   poster: "/j8K7vgF3Kp5T6EwJvez9B4it6CB.jpg", genre: "Animé"     },
  { title: "Supernatural",              poster: "/iBR4U3MZelj5avBqqs1SJpIqArP.jpg", genre: "Fantastique"},
  { title: "Un mauvais pressentiment",  poster: "/8UbrsXdkYtJOnHrrqVesQVxFZXW.jpg", genre: "Thriller"  },
];

const vodCategories = [
  { icon: "🎬", label: "Dernières Sorties", desc: "Films du cinéma récents", color: "#ef4444" },
  { icon: "🎭", label: "Séries Populaires", desc: "Series & mini-séries complètes", color: "#f97316" },
  { icon: "🌟", label: "Classiques du Cinéma", desc: "Films cultes en HD", color: "#f59e0b" },
  { icon: "📰", label: "Documentaires", desc: "Nature, histoire, science", color: "#22c55e" },
  { icon: "🦸", label: "Films d'Animation", desc: "Pour petits et grands", color: "#3D9BE9" },
  { icon: "🌍", label: "Cinéma International", desc: "Films du monde entier", color: "#8b5cf6" },
];

const genres = [
  "Action", "Aventure", "Romance", "Thriller", "Science-Fiction", "Comédie",
  "Horreur", "Animation", "Documentaire", "Drame", "Fantastique", "Biopic",
  "Crime", "Guerre", "Western", "Musical", "Jeunesse", "Sport"
];
---
<section id="vod" style="padding: 6rem 0; background: #050510; position: relative; overflow: hidden;">
  <!-- Cinematic atmosphere -->
  <div style="position: absolute; inset: 0; pointer-events: none;">
    <div style="position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, #f59e0b, transparent);"></div>
    <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, #f59e0b, transparent);"></div>
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 800px; height: 400px; background: radial-gradient(ellipse, rgba(245,158,11,0.04) 0%, transparent 70%);"></div>
    <!-- Film strip decoration left -->
    <div style="position: absolute; left: 0; top: 0; bottom: 0; width: 40px; background: repeating-linear-gradient(180deg, transparent 0px, transparent 40px, rgba(245,158,11,0.06) 40px, rgba(245,158,11,0.06) 50px); opacity: 0.5;"></div>
    <!-- Film strip decoration right -->
    <div style="position: absolute; right: 0; top: 0; bottom: 0; width: 40px; background: repeating-linear-gradient(180deg, transparent 0px, transparent 40px, rgba(245,158,11,0.06) 40px, rgba(245,158,11,0.06) 50px); opacity: 0.5;"></div>
  </div>

  <div style="max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; position: relative; z-index: 1;">

    <!-- Header -->
    <div style="text-align: center; margin-bottom: 4rem;">
      <div style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 14px; background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.3); border-radius: 20px; margin-bottom: 1.25rem;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
        <span style="color: #f59e0b; font-size: 0.8rem; font-weight: 600;">Films & Séries VOD</span>
      </div>
      <h2 style="font-family: 'Poppins', sans-serif; font-weight: 900; font-size: clamp(2rem, 4vw, 3rem); color: #f1f5f9; margin-bottom: 1rem; line-height: 1.2;">
        🎬 <span class="gradient-text-gold">+70 000 Films & Séries</span>
        <br />en VOD Illimitée
      </h2>
      <p style="color: #94a3b8; font-size: 1.05rem; max-width: 620px; margin: 0 auto; line-height: 1.8;">
        Plongez dans une <strong style="color: #f1f5f9;">bibliothèque cinématographique colossale</strong> — des dernières sorties aux classiques intemporels, des séries mondiales aux documentaires exclusifs.
      </p>
    </div>

    <!-- Films & Séries banner -->
    <div style="margin-bottom: 3.5rem;">
      <img
        src="/banner-films-series.jpeg"
        alt="Films & Séries en streaming — IPTV"
        style="width:100%;border-radius:16px;display:block;border:1px solid rgba(245,158,11,0.2);box-shadow:0 20px 60px rgba(245,158,11,0.12);"
      />
    </div>

    <!-- Main grid: categories left, cinema visual right -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; margin-bottom: 4rem;" class="vod-main-grid">

      <!-- Left: Categories -->
      <div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem;">
          {vodCategories.map(cat => (
            <div style={`background: rgba(15,15,26,0.9); border: 1px solid #1e293b; border-radius: 14px; padding: 1.25rem; transition: all 0.3s; cursor: default;`} class="card-hover">
              <div style="font-size: 1.8rem; margin-bottom: 0.6rem;">{cat.icon}</div>
              <h3 style={`font-family: 'Poppins', sans-serif; font-weight: 700; color: ${cat.color}; font-size: 0.9rem; margin-bottom: 0.3rem;`}>{cat.label}</h3>
              <p style="color: #64748b; font-size: 0.78rem;">{cat.desc}</p>
            </div>
          ))}
        </div>

        <!-- Genre tags -->
        <div>
          <p style="color: #64748b; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 0.75rem;">Genres disponibles :</p>
          <div style="display: flex; flex-wrap: wrap; gap: 8px;">
            {genres.map(genre => (
              <span style="background: rgba(245,158,11,0.06); border: 1px solid rgba(245,158,11,0.15); color: #94a3b8; padding: 5px 12px; border-radius: 20px; font-size: 0.78rem; font-weight: 500; transition: all 0.2s;" class="channel-badge">
                {genre}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: Cinema visual -->
      <div style="position: relative;">
        <!-- Cinema screen mockup -->
        <div style="background: linear-gradient(145deg, #0a0815, #050510); border: 1px solid rgba(245,158,11,0.2); border-radius: 20px; padding: 2rem; position: relative; overflow: hidden;">

          <!-- Film reel decoration -->
          <div style="position: absolute; top: -30px; right: -30px; opacity: 0.06;">
            <svg width="120" height="120" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="50" cy="50" r="45" stroke="#f59e0b" stroke-width="3"/>
              <circle cx="50" cy="50" r="15" stroke="#f59e0b" stroke-width="2"/>
              <circle cx="50" cy="20" r="6" fill="#f59e0b"/>
              <circle cx="50" cy="80" r="6" fill="#f59e0b"/>
              <circle cx="20" cy="50" r="6" fill="#f59e0b"/>
              <circle cx="80" cy="50" r="6" fill="#f59e0b"/>
            </svg>
          </div>

          <!-- "Now Playing" header -->
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <div style="width: 8px; height: 8px; background: #f59e0b; border-radius: 50%; animation: pulse-glow 2s ease-in-out infinite;"></div>
              <span style="color: #f59e0b; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">En ce moment</span>
            </div>
            <span style="color: #475569; font-size: 0.75rem;">70 283 titres</span>
          </div>

          <!-- Real poster grid (TMDB) -->
          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 1.5rem;">
            {trendingMovies.slice(0, 8).map(movie => (
              <div style="border-radius: 8px; aspect-ratio: 2/3; overflow: hidden; position: relative; transition: all 0.3s;" class="vod-card">
                <img
                  src={`${TMDB_IMG}${movie.poster}`}
                  alt={movie.title}
                  loading="lazy"
                  style="width:100%;height:100%;object-fit:cover;display:block;"
                />
                <div class="vod-overlay" style="position:absolute;inset:0;background:rgba(0,0,0,0.65);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;border-radius:7px;">
                  <div style="width:28px;height:28px;background:#f59e0b;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><polygon points="5,3 19,12 5,21"/></svg>
                  </div>
                  <span style="font-size:0.55rem;color:white;font-weight:700;text-align:center;padding:0 4px;line-height:1.2;">{movie.title}</span>
                </div>
              </div>
            ))}
          </div>

          <!-- Search bar simulation -->
          <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 10px 14px; display: flex; align-items: center; gap: 8px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span style="color: #475569; font-size: 0.82rem;">Rechercher un film, une série...</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats row -->
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 3rem;" class="vod-stats-grid">
      <div style="text-align: center; padding: 1.25rem; background: rgba(15,15,26,0.6); border: 1px solid rgba(245,158,11,0.15); border-radius: 12px;">
        <div style="font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 1.6rem; color: #f59e0b; margin-bottom: 0.25rem;">70 000+</div>
        <div style="color: #64748b; font-size: 0.8rem;">Titres VOD</div>
      </div>
      <div style="text-align: center; padding: 1.25rem; background: rgba(15,15,26,0.6); border: 1px solid rgba(245,158,11,0.15); border-radius: 12px;">
        <div style="font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 1.6rem; color: #f59e0b; margin-bottom: 0.25rem;">Quotidien</div>
        <div style="color: #64748b; font-size: 0.8rem;">Mise à jour du catalogue</div>
      </div>
      <div style="text-align: center; padding: 1.25rem; background: rgba(15,15,26,0.6); border: 1px solid rgba(245,158,11,0.15); border-radius: 12px;">
        <div style="font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 1.6rem; color: #f59e0b; margin-bottom: 0.25rem;">18+</div>
        <div style="color: #64748b; font-size: 0.8rem;">Genres disponibles</div>
      </div>
      <div style="text-align: center; padding: 1.25rem; background: rgba(15,15,26,0.6); border: 1px solid rgba(245,158,11,0.15); border-radius: 12px;">
        <div style="font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 1.6rem; color: #f59e0b; margin-bottom: 0.25rem;">4K</div>
        <div style="color: #64748b; font-size: 0.8rem;">Qualité max disponible</div>
      </div>
    </div>

    <!-- Trending Films row -->
    <div style="margin-bottom: 3rem;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
        <h3 style="font-family:'Poppins',sans-serif;font-weight:800;font-size:1.1rem;color:#f1f5f9;display:flex;align-items:center;gap:8px;">
          <span style="color:#f59e0b;">🎬</span> Films tendance en France
          <span style="font-family:monospace;font-size:0.65rem;color:#64748b;font-weight:400;margin-left:4px;">via TMDB</span>
        </h3>
        <span style="font-size:0.75rem;color:#475569;">2026</span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(10,1fr);gap:10px;overflow-x:auto;padding-bottom:8px;" class="poster-row">
        {trendingMovies.map(movie => (
          <div style="border-radius:10px;overflow:hidden;position:relative;aspect-ratio:2/3;flex-shrink:0;min-width:100px;transition:transform .25s;" class="poster-card">
            <img
              src={`${TMDB_IMG}${movie.poster}`}
              alt={movie.title}
              loading="lazy"
              style="width:100%;height:100%;object-fit:cover;display:block;"
            />
            <div style="position:absolute;bottom:0;left:0;right:0;padding:6px 8px;background:linear-gradient(to top,rgba(0,0,0,0.9),transparent);">
              <div style="font-size:0.62rem;color:#f59e0b;font-weight:700;letter-spacing:0.04em;">{movie.genre}</div>
              <div style="font-size:0.65rem;color:white;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{movie.title}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Trending Series row -->
    <div style="margin-bottom: 3.5rem;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
        <h3 style="font-family:'Poppins',sans-serif;font-weight:800;font-size:1.1rem;color:#f1f5f9;display:flex;align-items:center;gap:8px;">
          <span style="color:#f59e0b;">📺</span> Séries populaires
          <span style="font-family:monospace;font-size:0.65rem;color:#64748b;font-weight:400;margin-left:4px;">via TMDB</span>
        </h3>
        <span style="font-size:0.75rem;color:#475569;">2026</span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(10,1fr);gap:10px;overflow-x:auto;padding-bottom:8px;" class="poster-row">
        {trendingSeries.map(serie => (
          <div style="border-radius:10px;overflow:hidden;position:relative;aspect-ratio:2/3;flex-shrink:0;min-width:100px;transition:transform .25s;" class="poster-card">
            <img
              src={`${TMDB_IMG}${serie.poster}`}
              alt={serie.title}
              loading="lazy"
              style="width:100%;height:100%;object-fit:cover;display:block;"
            />
            <div style="position:absolute;bottom:0;left:0;right:0;padding:6px 8px;background:linear-gradient(to top,rgba(0,0,0,0.9),transparent);">
              <div style="font-size:0.62rem;color:#ef4444;font-weight:700;letter-spacing:0.04em;">{serie.genre}</div>
              <div style="font-size:0.65rem;color:white;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{serie.title}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div style="text-align: center;">
      <a
        href="https://wa.me/33XXXXXXXXX?text=Bonjour%2C+je+veux+acc%C3%A9der+aux+70+000+films+et+s%C3%A9ries+VOD+d%27Atlas+Pro+ONTV"
        target="_blank"
        rel="noopener"
        style="
          display: inline-flex;
          align-items: center;
          gap: 10px;
          padding: 16px 36px;
          background: linear-gradient(135deg, #f59e0b, #d97706);
          color: #050510;
          font-family: 'Poppins', sans-serif;
          font-weight: 800;
          font-size: 1.05rem;
          border-radius: 14px;
          text-decoration: none;
          box-shadow: 0 0 40px rgba(245,158,11,0.3);
          transition: all 0.3s;
        "
        onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 0 60px rgba(245,158,11,0.5)'"
        onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 0 40px rgba(245,158,11,0.3)'"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="#050510"><path d="M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.099 1.508 5.817L.057 23.887a.5.5 0 0 0 .556.556l6.07-1.451C8.362 23.658 10.118 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm5.53 17.12c-.272.767-1.571 1.462-2.147 1.524-.549.058-1.25.084-2.015-.124-.464-.13-1.059-.302-1.825-.631-3.21-1.387-5.3-4.626-5.462-4.839-.163-.214-1.329-1.768-1.329-3.374 0-1.604.839-2.392 1.137-2.718.271-.296.591-.37.789-.37.197 0 .394.002.566.01.182.008.426-.069.667.509.251.599.853 2.083.927 2.234.075.152.124.33.025.532-.099.2-.149.327-.296.503-.148.175-.311.392-.444.527-.148.148-.302.31-.13.607.173.297.769 1.268 1.651 2.053 1.133 1.011 2.089 1.325 2.386 1.473.297.148.47.124.643-.074.173-.198.74-.863 1.038-1.16.198-.198.397-.149.668.025.272.173 1.727.815 2.024.964.297.149.495.223.568.347.074.124.074.718-.198 1.485z"/></svg>
        Accéder à la VOD — Commander via WhatsApp
      </a>
      <p style="color: #475569; font-size: 0.8rem; margin-top: 0.75rem;">Inclus dans tous les abonnements dès 39,99€/an</p>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .vod-main-grid { grid-template-columns: 1fr !important; }
    .vod-stats-grid { grid-template-columns: repeat(2, 1fr) !important; }
    .poster-row { grid-template-columns: repeat(5, minmax(90px, 1fr)) !important; }
  }
  @media (max-width: 480px) {
    .poster-row { grid-template-columns: repeat(4, minmax(80px, 1fr)) !important; }
  }
  .poster-card:hover {
    transform: scale(1.05);
    z-index: 2;
  }
  .poster-card:hover img {
    filter: brightness(1.1);
  }
</style>

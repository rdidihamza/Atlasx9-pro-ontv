---
---
<section id="contact" style="position:relative;padding:7rem 0;background:var(--bg-section);overflow:hidden;">

  <!-- Orbs -->
  <div class="orb" style="width:600px;height:400px;background:radial-gradient(ellipse,rgba(16,185,129,0.05) 0%,transparent 70%);bottom:-80px;left:50%;transform:translateX(-50%);"></div>

  <!-- Top divider -->
  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>

  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1;">

    <!-- Header -->
    <div style="text-align:center;margin-bottom:4.5rem;" class="fade-in-up">
      <span class="section-label lbl-green">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Contact
      </span>
      <h2 style="font-family:var(--font-display);font-size:clamp(2.2rem,3.8vw,3.5rem);font-weight:700;line-height:1.1;color:var(--text);margin-top:0.75rem;margin-bottom:1.25rem;">
        On est là pour <em style="font-style:italic;color:var(--green);">vous aider</em>
      </h2>
      <p style="font-family:var(--font-body);font-size:1.05rem;color:var(--text-muted);max-width:480px;margin:0 auto;line-height:1.8;">
        Support francophone disponible <strong style="color:var(--text);">24h/24, 7j/7.</strong> Réponse en moins de 5 minutes.
      </p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;" class="contact-grid fade-in-up">

      <!-- ── LEFT: WhatsApp CTA + info cards ── -->
      <div style="display:flex;flex-direction:column;gap:1.25rem;">

        <!-- WhatsApp primary CTA -->
        <a
          href="https://wa.me/33XXXXXXXXX?text=Bonjour%2C+je+souhaite+commander+ou+tester+Atlas+Pro+ONTV"
          target="_blank"
          rel="noopener"
          style="display:flex;align-items:center;gap:16px;padding:1.5rem;background:linear-gradient(135deg,rgba(16,185,129,0.12),rgba(16,185,129,0.06));border:1px solid rgba(16,185,129,0.3);border-radius:18px;text-decoration:none;transition:all 0.3s;animation:pulse-green 2.5s ease-in-out infinite;"
        >
          <div style="width:58px;height:58px;background:var(--green);border-radius:16px;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 8px 24px rgba(16,185,129,0.3);">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.099 1.508 5.817L.057 23.887a.5.5 0 0 0 .556.556l6.07-1.451C8.362 23.658 10.118 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm5.53 17.12c-.272.767-1.571 1.462-2.147 1.524-.549.058-1.25.084-2.015-.124-.464-.13-1.059-.302-1.825-.631-3.21-1.387-5.3-4.626-5.462-4.839-.163-.214-1.329-1.768-1.329-3.374 0-1.604.839-2.392 1.137-2.718.271-.296.591-.37.789-.37.197 0 .394.002.566.01.182.008.426-.069.667.509.251.599.853 2.083.927 2.234.075.152.124.33.025.532-.099.2-.149.327-.296.503-.148.175-.311.392-.444.527-.148.148-.302.31-.13.607.173.297.769 1.268 1.651 2.053 1.133 1.011 2.089 1.325 2.386 1.473.297.148.47.124.643-.074.173-.198.74-.863 1.038-1.16.198-.198.397-.149.668.025.272.173 1.727.815 2.024.964.297.149.495.223.568.347.074.124.074.718-.198 1.485z"/>
            </svg>
          </div>
          <div style="flex:1;">
            <div style="font-family:var(--font-sans);font-weight:700;font-size:1.05rem;color:var(--text);margin-bottom:5px;">Commander via WhatsApp</div>
            <div style="display:flex;align-items:center;gap:7px;font-family:var(--font-body);font-size:0.83rem;color:var(--green);">
              <span style="width:7px;height:7px;background:var(--green);border-radius:50%;display:inline-block;animation:pulse-green 1.5s ease-in-out infinite;"></span>
              En ligne — réponse en &lt; 5 min
            </div>
          </div>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" style="flex-shrink:0;"><polyline points="9,18 15,12 9,6"/></svg>
        </a>

        <!-- Info cards -->
        {[
          {
            icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>`,
            title: "Horaires Support",
            desc: "24h/24, 7j/7 — Même les jours fériés",
            color: "var(--accent)",
            colorRgb: "79,142,247",
          },
          {
            icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
            title: "Livraison Immédiate",
            desc: "Accès envoyé en moins de 5 minutes",
            color: "var(--gold)",
            colorRgb: "232,160,32",
          },
          {
            icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
            title: "Support en Français",
            desc: "Équipe francophone dédiée",
            color: "#a78bfa",
            colorRgb: "167,139,250",
          },
        ].map(item => (
          <div class="glass" style="border-radius:14px;padding:1rem 1.25rem;display:flex;align-items:center;gap:12px;">
            <div style={`width:40px;height:40px;background:rgba(${item.colorRgb},0.1);border:1px solid rgba(${item.colorRgb},0.2);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;`} set:html={item.icon} />
            <div>
              <div style="font-family:var(--font-sans);font-weight:700;font-size:0.875rem;color:var(--text);margin-bottom:2px;">{item.title}</div>
              <div style="font-family:var(--font-body);font-size:0.8rem;color:var(--text-muted);">{item.desc}</div>
            </div>
          </div>
        ))}
      </div>

      <!-- ── RIGHT: Contact form ── -->
      <div class="glass" style="border-radius:20px;padding:2rem;">
        <h3 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--text);margin-bottom:1.75rem;line-height:1.2;">Envoyer un message</h3>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          style="display:flex;flex-direction:column;gap:1rem;"
        >
          <input type="hidden" name="form-name" value="contact" />
          <input name="bot-field" style="display:none;" />

          <!-- Prénom + Nom -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div>
              <label style="display:block;font-family:var(--font-sans);color:var(--text-muted);font-size:0.75rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:7px;">Prénom</label>
              <input
                type="text" name="prenom" required placeholder="Marie"
                style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:11px 14px;color:var(--text);font-family:var(--font-body);font-size:0.875rem;outline:none;transition:border-color 0.2s;"
              />
            </div>
            <div>
              <label style="display:block;font-family:var(--font-sans);color:var(--text-muted);font-size:0.75rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:7px;">Nom</label>
              <input
                type="text" name="nom" required placeholder="Dupont"
                style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:11px 14px;color:var(--text);font-family:var(--font-body);font-size:0.875rem;outline:none;transition:border-color 0.2s;"
              />
            </div>
          </div>

          <!-- Email -->
          <div>
            <label style="display:block;font-family:var(--font-sans);color:var(--text-muted);font-size:0.75rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:7px;">Email</label>
            <input
              type="email" name="email" required placeholder="marie@exemple.fr"
              style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:11px 14px;color:var(--text);font-family:var(--font-body);font-size:0.875rem;outline:none;transition:border-color 0.2s;"
            />
          </div>

          <!-- Sujet -->
          <div>
            <label style="display:block;font-family:var(--font-sans);color:var(--text-muted);font-size:0.75rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:7px;">Sujet</label>
            <select
              name="sujet"
              style="width:100%;background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:11px 14px;color:var(--text);font-family:var(--font-body);font-size:0.875rem;outline:none;cursor:pointer;transition:border-color 0.2s;"
            >
              <option value="commande">Commander un abonnement</option>
              <option value="test">Demander un test gratuit 24h</option>
              <option value="support">Support technique</option>
              <option value="renouvellement">Renouvellement</option>
              <option value="autre">Autre question</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label style="display:block;font-family:var(--font-sans);color:var(--text-muted);font-size:0.75rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:7px;">Message</label>
            <textarea
              name="message" required rows="4" placeholder="Bonjour, je souhaite…"
              style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:11px 14px;color:var(--text);font-family:var(--font-body);font-size:0.875rem;outline:none;resize:vertical;transition:border-color 0.2s;line-height:1.6;"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="btn-primary"
            style="justify-content:center;padding:14px;font-size:0.9rem;"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22,2 15,22 11,13 2,9"/></svg>
            Envoyer le message
          </button>
        </form>
      </div>

    </div>
  </div>

  <!-- Bottom divider -->
  <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
</section>

<!-- Floating WhatsApp button -->
<a
  href="https://wa.me/33XXXXXXXXX?text=Bonjour%2C+je+souhaite+plus+d%27informations+sur+Atlas+Pro+ONTV"
  target="_blank"
  rel="noopener"
  class="whatsapp-float"
  aria-label="Contacter sur WhatsApp"
  style="width:58px;height:58px;background:var(--green);border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 24px rgba(16,185,129,0.45);text-decoration:none;"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
    <path d="M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.099 1.508 5.817L.057 23.887a.5.5 0 0 0 .556.556l6.07-1.451C8.362 23.658 10.118 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm5.53 17.12c-.272.767-1.571 1.462-2.147 1.524-.549.058-1.25.084-2.015-.124-.464-.13-1.059-.302-1.825-.631-3.21-1.387-5.3-4.626-5.462-4.839-.163-.214-1.329-1.768-1.329-3.374 0-1.604.839-2.392 1.137-2.718.271-.296.591-.37.789-.37.197 0 .394.002.566.01.182.008.426-.069.667.509.251.599.853 2.083.927 2.234.075.152.124.33.025.532-.099.2-.149.327-.296.503-.148.175-.311.392-.444.527-.148.148-.302.31-.13.607.173.297.769 1.268 1.651 2.053 1.133 1.011 2.089 1.325 2.386 1.473.297.148.47.124.643-.074.173-.198.74-.863 1.038-1.16.198-.198.397-.149.668.025.272.173 1.727.815 2.024.964.297.149.495.223.568.347.074.124.074.718-.198 1.485z"/>
  </svg>
</a>

<style>
  @media (max-width: 780px) {
    .contact-grid { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('#contact .fade-in-up').forEach(el => obs.observe(el));
</script>

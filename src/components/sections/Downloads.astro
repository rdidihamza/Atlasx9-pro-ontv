---
import { ANDROID_APPS, OTHER_PLATFORMS } from '../../data/downloads';

const badgeStyles: Record<string, { bg: string; border: string; text: string }> = {
  green:  { bg: 'rgba(16,185,129,0.12)',  border: 'rgba(16,185,129,0.3)',  text: 'var(--green)'  },
  blue:   { bg: 'rgba(79,142,247,0.12)',  border: 'rgba(79,142,247,0.3)',  text: 'var(--accent)' },
  purple: { bg: 'rgba(139,92,246,0.12)',  border: 'rgba(139,92,246,0.3)',  text: '#a78bfa'        },
  gold:   { bg: 'rgba(232,160,32,0.12)',  border: 'rgba(232,160,32,0.3)',  text: 'var(--gold)'   },
};
---
<section id="telecharger" style="position:relative;padding:7rem 0;background:var(--bg-section);overflow:hidden;" class="bg-grid">

  <!-- Orbs -->
  <div class="orb" style="width:500px;height:500px;background:radial-gradient(circle,rgba(16,185,129,0.07) 0%,transparent 70%);top:-80px;right:-100px;"></div>

  <!-- Top divider -->
  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>

  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1;">

    <!-- Header -->
    <div style="text-align:center;margin-bottom:4.5rem;" class="fade-in-up">
      <span class="section-label lbl-green">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Téléchargement
      </span>
      <h2 style="font-family:var(--font-display);font-size:clamp(2.2rem,3.8vw,3.5rem);font-weight:700;line-height:1.1;color:var(--text);margin-top:0.75rem;margin-bottom:1.25rem;">
        Installez <em style="font-style:italic;color:var(--accent);">Atlas Pro</em> sur votre appareil
      </h2>
      <p style="font-family:var(--font-body);font-size:1.05rem;color:var(--text-muted);max-width:580px;margin:0 auto;line-height:1.8;">
        Installation en 3 étapes via l'application <strong style="color:var(--text);">Downloader</strong>. Aucun Play Store nécessaire.
      </p>
    </div>

    <!-- Step instruction bar -->
    <div class="glass fade-in-up" style="border-radius:14px;padding:1.5rem 2rem;margin-bottom:3.5rem;display:flex;align-items:center;justify-content:center;gap:0;flex-wrap:wrap;" id="download-steps">
      {[
        { n: "01", text: "Téléchargez Downloader", icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/></svg>` },
        { n: "02", text: "Entrez le code APK",     icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>` },
        { n: "03", text: "Installez & profitez",   icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5,3 19,12 5,21"/></svg>` },
      ].map((step, i) => (
        <>
          <div style="display:flex;align-items:center;gap:10px;padding:0 1.5rem;">
            <div style="width:32px;height:32px;background:var(--accent-dim);border:1px solid var(--border-accent);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <span style="color:var(--accent);display:flex;align-items:center;justify-content:center;" set:html={step.icon} />
            </div>
            <div>
              <div style="font-family:var(--font-mono);font-size:0.65rem;color:var(--accent);letter-spacing:0.1em;margin-bottom:1px;">{step.n}</div>
              <div style="font-family:var(--font-sans);font-weight:600;font-size:0.85rem;color:var(--text);">{step.text}</div>
            </div>
          </div>
          {i < 2 && (
            <div style="width:2rem;height:1px;background:var(--border);flex-shrink:0;" class="step-sep"></div>
          )}
        </>
      ))}
    </div>

    <!-- Firestick tip -->
    <div style="display:flex;align-items:flex-start;gap:12px;padding:1rem 1.5rem;background:rgba(79,142,247,0.06);border:1px solid var(--border-accent);border-radius:12px;margin-bottom:3rem;" class="fade-in-up">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <p style="font-family:var(--font-body);font-size:0.875rem;color:var(--text-muted);line-height:1.7;margin:0;">
        <strong style="color:var(--text);">Firestick :</strong> Activez les sources inconnues dans
        <strong style="color:var(--accent);">Paramètres → Ma Fire TV → Options développeur</strong> avant l'installation.
      </p>
    </div>

    <!-- Android APK cards -->
    <h3 style="font-family:var(--font-sans);font-weight:700;font-size:1.05rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--text-muted);margin-bottom:1.5rem;display:flex;align-items:center;gap:10px;" class="fade-in-up">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      Android · Firestick · Smart TV — Codes Downloader
    </h3>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-bottom:3.5rem;" class="apk-grid">
      {ANDROID_APPS.map((app, i) => {
        const bs = app.badgeColor ? (badgeStyles[app.badgeColor] || badgeStyles.blue) : null;
        return (
          <div
            class={`glass card-hover fade-in-up delay-${(i % 3) + 1}`}
            style="border-radius:16px;padding:1.6rem;position:relative;overflow:hidden;"
          >
            <!-- Badge -->
            {app.badge && bs && (
              <span style={`position:absolute;top:14px;right:14px;padding:3px 10px;border-radius:20px;font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.08em;background:${bs.bg};border:1px solid ${bs.border};color:${bs.text};`}>
                {app.badge}
              </span>
            )}

            <!-- App icon + name -->
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:1rem;">
              <div style="width:44px;height:44px;background:var(--accent-dim);border:1px solid var(--border-accent);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
              </div>
              <div>
                <div style="font-family:var(--font-sans);font-weight:700;font-size:0.92rem;color:var(--text);margin-bottom:2px;">{app.name}</div>
                <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--text-muted);">{app.version}</div>
              </div>
            </div>

            <p style="font-family:var(--font-body);font-size:0.83rem;color:var(--text-muted);margin-bottom:1.25rem;line-height:1.65;">{app.description}</p>

            <!-- Code + copy -->
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="flex:1;background:rgba(0,0,0,0.35);border:1px solid var(--border);border-radius:10px;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;gap:8px;">
                <span style="font-family:var(--font-mono);font-size:1.15rem;font-weight:600;color:var(--green);letter-spacing:3px;" id={`code-${app.code}`}>{app.code}</span>
                <span style="font-family:var(--font-sans);font-size:0.62rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-muted);white-space:nowrap;">Code</span>
              </div>
              <button
                class="copy-btn"
                data-code={app.code}
                aria-label={`Copier le code ${app.code}`}
                style="padding:10px 14px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.25);border-radius:10px;color:var(--green);font-family:var(--font-sans);font-weight:700;font-size:0.78rem;cursor:pointer;transition:all 0.2s;white-space:nowrap;display:flex;align-items:center;gap:6px;"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                Copier
              </button>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Other platforms -->
    <h3 style="font-family:var(--font-sans);font-weight:700;font-size:1.05rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--text-muted);margin-bottom:1.5rem;display:flex;align-items:center;gap:10px;" class="fade-in-up">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
      iOS · PC · macOS · Apple TV · MAG
    </h3>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;" class="platforms-grid">
      {OTHER_PLATFORMS.map((p, i) => (
        <div
          class={`glass card-hover fade-in-up delay-${(i % 4) + 1}`}
          style="border-radius:12px;padding:1.1rem 1.25rem;display:flex;align-items:center;justify-content:space-between;gap:0.75rem;"
        >
          <div>
            <div style="font-family:var(--font-sans);font-weight:600;font-size:0.85rem;color:var(--text);margin-bottom:2px;">{p.platform}</div>
            <div style="font-family:var(--font-body);font-size:0.78rem;color:var(--text-muted);">{p.app}</div>
          </div>
          <a
            href={p.link}
            style="flex-shrink:0;padding:5px 12px;background:var(--accent-dim);border:1px solid var(--border-accent);border-radius:8px;color:var(--accent);font-family:var(--font-sans);font-size:0.72rem;font-weight:700;text-decoration:none;letter-spacing:0.04em;white-space:nowrap;transition:all 0.2s;"
          >
            {p.store}
          </a>
        </div>
      ))}
    </div>

  </div>

  <!-- Bottom divider -->
  <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
</section>

<style>
  @media (max-width: 1100px) { .apk-grid { grid-template-columns: repeat(2, 1fr) !important; } }
  @media (max-width: 680px)  { .apk-grid, .platforms-grid { grid-template-columns: 1fr !important; } }
  @media (max-width: 900px)  { .platforms-grid { grid-template-columns: repeat(2, 1fr) !important; } }
  @media (max-width: 580px)  { .step-sep { display: none !important; } }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('#telecharger .fade-in-up').forEach(el => obs.observe(el));

  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const code = btn.dataset.code || '';
      navigator.clipboard.writeText(code).then(() => {
        btn.classList.add('copied');
        btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg> Copié&nbsp;!`;
        setTimeout(() => {
          btn.classList.remove('copied');
          btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copier`;
        }, 2500);
      });
    });
  });
</script>

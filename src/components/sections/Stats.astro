---
const stats = [
  { display: '+15 000', label: 'Chaînes en Direct',      sub: 'HD · Full HD · 4K UHD',         color: '#E8192C', colorRgb: '232,25,44'  },
  { display: '+70 000', label: 'Films & Séries VOD',     sub: 'Dernières sorties incluses',     color: '#FFC107', colorRgb: '255,193,7'  },
  { display: '50 000+', label: 'Abonnés Satisfaits',     sub: 'Note moyenne 4.8 / 5',           color: '#22C55E', colorRgb: '34,197,94'  },
  { display: '99.9%',   label: 'Garantie Disponibilité', sub: 'Serveurs Europe redondants',     color: '#6FA0FF', colorRgb: '111,160,255' },
];
---
<section id="chiffres" style="position:relative;padding:6rem 0;background:var(--bg-section);overflow:hidden;">

  <!-- Subtle grid -->
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(232,25,44,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(232,25,44,.018) 1px,transparent 1px);background-size:64px 64px;pointer-events:none;"></div>

  <!-- Red glow center -->
  <div class="orb" style="width:600px;height:300px;background:radial-gradient(ellipse,rgba(232,25,44,0.06) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);"></div>

  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>

  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1;">

    <!-- Header -->
    <div style="text-align:center;margin-bottom:4rem;" class="fade-in-up">
      <span class="section-label lbl-red">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>
        Chiffres Clés
      </span>
      <h2 style="font-family:'Outfit',sans-serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:800;color:#fff;margin-top:0.75rem;line-height:1.1;">
        Atlas Pro ONTV <span style="color:var(--accent);">en chiffres</span>
      </h2>
    </div>

    <!-- Stats grid — filmbox card style -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;" class="stats-grid fade-in-up" id="stats-section">
      {stats.map((stat, i) => (
        <div style={`
          background: var(--bg-card);
          border: 1px solid var(--border);
          border-top: 3px solid ${stat.color};
          border-radius: 14px;
          padding: 2.25rem 1.75rem;
          text-align: center;
          position: relative;
          overflow: hidden;
          transition: transform .3s ease, box-shadow .3s ease;
        `}
          onmouseover={`this.style.transform='translateY(-4px)';this.style.boxShadow='0 20px 50px rgba(${stat.colorRgb},0.15)'`}
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='none'"
        >
          <!-- Background glow -->
          <div style={`position:absolute;top:0;left:50%;transform:translateX(-50%);width:80%;height:1px;background:linear-gradient(90deg,transparent,${stat.color},transparent);`}></div>

          <div
            class="stat-count"
            data-target={stat.display}
            data-display={stat.display}
            style={`font-family:'Outfit',sans-serif;font-size:clamp(2.5rem,4vw,3.75rem);font-weight:900;color:${stat.color};line-height:1;margin-bottom:0.75rem;letter-spacing:-0.02em;`}
          >
            {stat.display}
          </div>

          <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:0.9rem;color:#fff;margin-bottom:0.4rem;">
            {stat.label}
          </div>
          <div style="font-family:'Barlow',sans-serif;font-size:0.8rem;color:var(--text-muted);">{stat.sub}</div>
        </div>
      ))}
    </div>
  </div>

  <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
</section>

<style>
  @media (max-width: 900px)  { .stats-grid { grid-template-columns: repeat(2, 1fr) !important; } }
  @media (max-width: 480px)  { .stats-grid { grid-template-columns: 1fr !important; } }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('#chiffres .fade-in-up').forEach(el => obs.observe(el));
</script>

              <span style="font-size:1.6rem;">{d.icon}</span>
              <span style="font-family:'Outfit',sans-serif;font-size:0.78rem;font-weight:600;color:var(--text-muted);white-space:nowrap;">{d.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SECTION 7: CONTENT CATEGORIES
    ══════════════════════════════════════════ -->
    <section style="position:relative;padding:6rem 0;background:var(--bg-section);overflow:hidden;">
      <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
      <div style="max-width:1280px;margin:0 auto;padding:0 2rem;position:relative;z-index:1;">

        <div style="text-align:center;margin-bottom:3rem;">
          <h2 style="font-family:'Outfit',sans-serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:800;color:#fff;line-height:1.1;">
            Tout le contenu dont vous avez <span style="color:var(--accent);">besoin</span>
          </h2>
        </div>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;" class="categories-grid">
          {categories.map(cat => (
            <div style={`background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:1.75rem;display:flex;align-items:flex-start;gap:1rem;transition:all .3s ease;position:relative;overflow:hidden;`}
              onmouseover={`this.style.borderColor='${cat.color}55';this.style.transform='translateY(-3px)'`}
              onmouseout="this.style.borderColor='var(--border)';this.style.transform='translateY(0)'"
            >
              <div style={`width:48px;height:48px;background:${cat.color}18;border:1px solid ${cat.color}33;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;`}>{cat.icon}</div>
              <div style="flex:1;">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:0.4rem;">
                  <h3 style="font-family:'Outfit',sans-serif;font-weight:700;font-size:0.95rem;color:#fff;">{cat.title}</h3>
                  <span style={`font-family:'Outfit',sans-serif;font-size:0.65rem;font-weight:700;background:${cat.color}22;color:${cat.color};padding:2px 8px;border-radius:10px;flex-shrink:0;`}>{cat.count}</span>
                </div>
                <p style="font-family:'Barlow',sans-serif;font-size:0.82rem;color:var(--text-muted);line-height:1.55;">{cat.sub}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
    </section>

    <!-- ══════════════════════════════════════════
         SECTION 8: 3 REVIEWS
    ══════════════════════════════════════════ -->
    <section style="position:relative;padding:6rem 0;background:var(--bg);overflow:hidden;">
      <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
      <div style="max-width:1280px;margin:0 auto;padding:0 2rem;position:relative;z-index:1;">

        <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;margin-bottom:3rem;">
          <div>
            <h2 style="font-family:'Outfit',sans-serif;font-size:clamp(1.8rem,3vw,2.6rem);font-weight:800;color:#fff;line-height:1.1;">
              Ce que disent nos <span style="color:var(--accent);">clients</span>
            </h2>
            <div style="display:flex;align-items:center;gap:10px;margin-top:0.75rem;">
              <span style="color:var(--gold);font-size:1rem;letter-spacing:2px;">★★★★★</span>
              <span style="font-family:'Outfit',sans-serif;font-weight:700;color:var(--gold);">{AGGREGATE_RATING.ratingValue}/5</span>
              <span style="font-family:'Barlow',sans-serif;font-size:0.85rem;color:var(--text-muted);">— {AGGREGATE_RATING.ratingCount.toLocaleString('fr-FR')} avis vérifiés</span>
            </div>
          </div>
          <a href="/avis" style="font-family:'Outfit',sans-serif;font-weight:600;font-size:0.9rem;color:var(--accent);text-decoration:none;border:1px solid rgba(232,25,44,0.3);padding:8px 18px;border-radius:8px;transition:all .2s;"
            onmouseover="this.style.background='rgba(232,25,44,0.1)'"
            onmouseout="this.style.background='transparent'"
          >Voir tous les avis →</a>
        </div>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;" class="reviews-preview-grid">
          {threeReviews.map((review, i) => (
            <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:1.75rem;display:flex;flex-direction:column;gap:1rem;position:relative;overflow:hidden;transition:all .3s ease;"
              onmouseover="this.style.borderColor='rgba(232,25,44,0.3)';this.style.transform='translateY(-3px)'"
              onmouseout="this.style.borderColor='var(--border)';this.style.transform='translateY(0)'"
            >
              <span style="font-family:'Outfit',sans-serif;font-size:4rem;line-height:0.7;color:var(--accent);opacity:0.08;position:absolute;top:0.75rem;right:1.25rem;font-weight:900;">"</span>
              <div style="color:var(--gold);font-size:0.85rem;letter-spacing:2px;">{'★'.repeat(review.rating)}</div>
              <blockquote style="font-family:'Barlow',sans-serif;font-style:italic;font-size:0.95rem;line-height:1.75;color:var(--text-muted);flex:1;">"{review.text}"</blockquote>
              <div style="display:flex;align-items:center;gap:10px;padding-top:1rem;border-top:1px solid var(--border);">
                <div style={`width:36px;height:36px;background:${avatarColors[i]};border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
                  <span style="font-family:'Outfit',sans-serif;font-weight:800;font-size:0.85rem;color:white;">{review.author.charAt(0)}</span>
                </div>
                <div>
                  <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:0.85rem;color:#fff;">{review.author}</div>
                  <div style="font-family:'Barlow',sans-serif;color:var(--text-muted);font-size:0.75rem;">{review.location}</div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div style="text-align:center;margin-top:2.5rem;">
          <a href="/avis" style="font-family:'Outfit',sans-serif;font-weight:600;font-size:0.95rem;color:var(--text-muted);text-decoration:none;transition:color .2s;"
            onmouseover="this.style.color='#fff'"
            onmouseout="this.style.color='var(--text-muted)'"
          >Voir tous les avis clients →</a>
        </div>
      </div>
      <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
    </section>

    <!-- ══════════════════════════════════════════
         SECTION 9: QUICK FAQ
    ══════════════════════════════════════════ -->
    <section id="faq" style="position:relative;padding:6rem 0;background:var(--bg-section);overflow:hidden;">
      <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
      <div style="max-width:800px;margin:0 auto;padding:0 2rem;position:relative;z-index:1;">

        <div style="text-align:center;margin-bottom:3rem;">
          <h2 style="font-family:'Outfit',sans-serif;font-size:clamp(1.8rem,3vw,2.6rem);font-weight:800;color:#fff;line-height:1.1;">

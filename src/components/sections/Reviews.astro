---
import { CUSTOMER_REVIEWS, AGGREGATE_RATING } from '../../data/reviews';

const avatarColors = [
  '#E8192C', '#FFC107', '#22C55E', '#6FA0FF', '#F97316', '#22D3EE',
];
---
<section id="avis" style="position:relative;padding:7rem 0;background:var(--bg-section);overflow:hidden;">

  <div class="orb" style="width:600px;height:300px;background:radial-gradient(ellipse,rgba(232,25,44,0.05) 0%,transparent 70%);bottom:-80px;left:-100px;"></div>
  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>

  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1;">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:4rem;flex-wrap:wrap;gap:1.5rem;" class="fade-in-up">
      <div>
        <span class="section-label lbl-gold">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Avis Clients
        </span>
        <h2 style="font-family:'Outfit',sans-serif;font-size:clamp(2.2rem,3.8vw,3.2rem);font-weight:800;color:#fff;margin-top:0.75rem;line-height:1.1;">
          Ils ont adopté <span style="color:var(--accent);">Atlas Pro ONTV</span>
        </h2>
      </div>

      <!-- Aggregate rating (filmbox IMDb-style) -->
      <div style="display:flex;align-items:center;gap:16px;padding:1.25rem 1.75rem;background:var(--bg-card);border:1px solid rgba(255,193,7,0.2);border-radius:14px;">
        <div style="text-align:center;">
          <div style="font-family:'Outfit',sans-serif;font-size:3rem;font-weight:900;color:var(--gold);line-height:1;">{AGGREGATE_RATING.ratingValue}</div>
          <div style="font-family:'Outfit',sans-serif;font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);margin-top:2px;">sur 5</div>
        </div>
        <div style="width:1px;height:50px;background:var(--border);"></div>
        <div>
          <div class="stars" style="font-size:1rem;letter-spacing:2px;margin-bottom:0.4rem;">★★★★★</div>
          <div style="font-family:'Barlow',sans-serif;font-size:0.82rem;color:var(--text-muted);">{AGGREGATE_RATING.ratingCount.toLocaleString('fr-FR')} avis vérifiés</div>
          <div style="font-family:'Outfit',sans-serif;font-size:0.68rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--green);margin-top:3px;">Clients satisfaits</div>
        </div>
      </div>
    </div>

    <!-- Review cards grid -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;" class="reviews-grid">
      {CUSTOMER_REVIEWS.map((review, i) => (
        <div
          class={`fade-in-up delay-${(i % 3) + 1}`}
          style={`
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 1.75rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            position: relative;
            overflow: hidden;
            transition: all .3s ease;
          `}
          onmouseover="this.style.borderColor='rgba(232,25,44,0.3)';this.style.transform='translateY(-3px)'"
          onmouseout="this.style.borderColor='var(--border)';this.style.transform='translateY(0)'"
        >
          <!-- Quote decoration -->
          <span style="font-family:'Outfit',sans-serif;font-size:4.5rem;line-height:0.7;color:var(--accent);opacity:0.08;position:absolute;top:0.75rem;right:1.25rem;user-select:none;pointer-events:none;font-weight:900;">"</span>

          <!-- Stars -->
          <div class="stars" style="font-size:0.85rem;letter-spacing:2px;position:relative;z-index:1;">
            {'★'.repeat(review.rating)}{'☆'.repeat(5 - review.rating)}
          </div>

          <!-- Review text -->
          <blockquote style="font-family:'Barlow',sans-serif;font-style:italic;font-size:0.95rem;line-height:1.75;color:var(--text-dim);flex:1;position:relative;z-index:1;">
            "{review.text}"
          </blockquote>

          <!-- Author row -->
          <div style="display:flex;align-items:center;gap:10px;padding-top:1rem;border-top:1px solid var(--border);">
            <div style={`width:36px;height:36px;background:${avatarColors[i % avatarColors.length]};border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
              <span style="font-family:'Outfit',sans-serif;font-weight:800;font-size:0.85rem;color:white;">{review.author.charAt(0)}</span>
            </div>
            <div style="flex:1;">
              <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:0.85rem;color:#fff;">{review.author}</div>
              <div style="font-family:'Barlow',sans-serif;color:var(--text-muted);font-size:0.75rem;">
                {review.location} · {new Date(review.date).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}
              </div>
            </div>
            <!-- Verified checkmark -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5" style="flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22,4 12,14.01 9,11.01"/></svg>
          </div>
        </div>
      ))}

      <!-- CTA card -->
      <div
        class="fade-in-up delay-3"
        style="border-radius:14px;padding:1.75rem;background:linear-gradient(135deg,rgba(232,25,44,0.08) 0%,rgba(255,193,7,0.04) 100%);border:1px solid var(--border-accent);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:1.25rem;"
      >
        <div class="stars" style="font-size:1.35rem;letter-spacing:4px;">★★★★★</div>
        <div>
          <h3 style="font-family:'Outfit',sans-serif;font-size:1.4rem;font-weight:800;color:#fff;margin-bottom:0.5rem;line-height:1.2;">
            Rejoignez +50 000 abonnés satisfaits
          </h3>
          <p style="font-family:'Barlow',sans-serif;font-size:0.875rem;color:var(--text-muted);line-height:1.65;">
            Testez pendant 24h gratuitement et formez-vous votre propre avis.
          </p>
        </div>
        <a
          href="https://wa.me/33XXXXXXXXX?text=Bonjour%2C+je+voudrais+tester+Atlas+Pro+ONTV+24h"
          target="_blank"
          rel="noopener"
          class="btn-orange"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.099 1.508 5.817L.057 23.887a.5.5 0 0 0 .556.556l6.07-1.451C8.362 23.658 10.118 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm5.53 17.12c-.272.767-1.571 1.462-2.147 1.524-.549.058-1.25.084-2.015-.124-.464-.13-1.059-.302-1.825-.631-3.21-1.387-5.3-4.626-5.462-4.839-.163-.214-1.329-1.768-1.329-3.374 0-1.604.839-2.392 1.137-2.718.271-.296.591-.37.789-.37.197 0 .394.002.566.01.182.008.426-.069.667.509.251.599.853 2.083.927 2.234.075.152.124.33.025.532-.099.2-.149.327-.296.503-.148.175-.311.392-.444.527-.148.148-.302.31-.13.607.173.297.769 1.268 1.651 2.053 1.133 1.011 2.089 1.325 2.386 1.473.297.148.47.124.643-.074.173-.198.74-.863 1.038-1.16.198-.198.397-.149.668.025.272.173 1.727.815 2.024.964.297.149.495.223.568.347.074.124.074.718-.198 1.485z"/></svg>
          Essai gratuit 24h
        </a>
      </div>
    </div>

  </div>

  <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
</section>

<style>
  @media (max-width: 1100px) { .reviews-grid { grid-template-columns: repeat(2, 1fr) !important; } }
  @media (max-width: 680px)  { .reviews-grid { grid-template-columns: 1fr !important; } }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('#avis .fade-in-up').forEach(el => obs.observe(el));
</script>

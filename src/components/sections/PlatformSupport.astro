---
<section id="appareils" style="padding: 6rem 0; background: var(--bg-section); position:relative; overflow:hidden;">
  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
  <div style="max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; position:relative;z-index:1;">
    <!-- Header -->
    <div style="text-align: center; margin-bottom: 4rem;" class="fade-in-up">
      <span class="section-label lbl-red">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        Multi-Appareils
      </span>
      <h2 style="font-family:'Outfit',sans-serif; font-weight: 800; font-size: clamp(2rem, 3.5vw, 3rem); color: #fff; margin-top:0.75rem; margin-bottom: 1rem; line-height:1.1;">
        Compatible avec <span style="color:var(--accent);">tous vos appareils</span>
      </h2>
      <p style="font-family:'Barlow',sans-serif; color: var(--text-muted); font-size: 1rem; max-width: 540px; margin: 0 auto; line-height:1.8;">
        Regardez Atlas Pro ONTV sur n'importe quel écran — télévision, smartphone, tablette ou ordinateur.
      </p>
    </div>

    <!-- Platform cards grid -->
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;" class="platforms-grid fade-in-up">
      {platforms.map(platform => (
        <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; transition: all 0.3s;"
          onmouseover="this.style.borderColor='rgba(232,25,44,0.3)';this.style.transform='translateY(-3px)'"
          onmouseout="this.style.borderColor='var(--border)';this.style.transform='translateY(0)'"
        >
          <!-- Card header -->
          <div style="padding: 1.5rem 1.5rem 0;">
            <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1rem;">
              <div style="width:50px;height:50px;background:var(--bg-elevated);border:1px solid var(--border);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                <Fragment set:html={platform.icon} />
              </div>
              {platform.badge && (
                <span style={`background:rgba(${platform.badgeColor === '#22c55e' ? '34,197,94' : '249,115,22'},0.1);border:1px solid rgba(${platform.badgeColor === '#22c55e' ? '34,197,94' : '249,115,22'},0.3);color:${platform.badgeColor};padding:3px 10px;border-radius:20px;font-family:'Outfit',sans-serif;font-size:0.68rem;font-weight:700;letter-spacing:0.06em;`}>
                  {platform.badge}
                </span>
              )}
            </div>
            <h3 style="font-family:'Outfit',sans-serif;font-weight:700;color:#fff;font-size:0.95rem;margin-bottom:0.4rem;">{platform.name}</h3>
            <p style="font-family:'Barlow',sans-serif;color:var(--text-muted);font-size:0.83rem;margin-bottom:1.25rem;">{platform.desc}</p>
          </div>

          <!-- Collapsible guide -->
          <details style="border-top:1px solid var(--border);">
            <summary style="padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;color:var(--accent);font-family:'Outfit',sans-serif;font-size:0.83rem;font-weight:600;cursor:pointer;user-select:none;">
              Voir le guide d'installation
              <svg class="faq-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><polyline points="6,9 12,15 18,9"/></svg>
            </summary>
            <div style="padding:0 1.5rem 1.5rem;">
              <div style="background:var(--accent-muted);border:1px solid var(--border-accent);border-radius:8px;padding:0.875rem;">
                <pre style="color:var(--text-dim);font-family:'JetBrains Mono',monospace;font-size:0.75rem;line-height:1.7;white-space:pre-wrap;margin:0;">{platform.guide}</pre>
              </div>
              <a
                href="/telechargement"
                style="display:inline-flex;align-items:center;gap:6px;margin-top:0.875rem;color:var(--accent);font-family:'Outfit',sans-serif;font-size:0.8rem;font-weight:600;text-decoration:none;"
              >
                Guide complet →
              </a>
            </div>
          </details>
        </div>
      ))}
    </div>

    <!-- Bottom note -->
    <div style="text-align:center;margin-top:3rem;" class="fade-in-up">
      <p style="font-family:'Barlow',sans-serif;color:var(--text-muted);font-size:0.875rem;">
        Besoin d'aide pour l'installation ?
        <a
          href="https://wa.me/33XXXXXXXXX?text=Bonjour%2C+j%27ai+besoin+d%27aide+pour+installer+Atlas+Pro+ONTV"
          target="_blank"
          rel="noopener"
          style="color:var(--green);font-family:'Outfit',sans-serif;font-weight:600;text-decoration:none;margin-left:4px;"
        >
          Contactez notre support WhatsApp
        </a>
        — réponse en moins de 5 minutes.
      </p>
    </div>
  </div>
  <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);"></div>
</section>

<style>
  @media (max-width: 1024px) {
    .platforms-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 600px) {
    .platforms-grid { grid-template-columns: 1fr !important; }
  }
</style>

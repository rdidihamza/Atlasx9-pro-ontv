---
import BaseLayout from '../components/layout/BaseLayout.astro';
import AnnouncementBar from '../components/layout/AnnouncementBar.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="Page introuvable (404) — Atlas Pro ONTV"
  description="Cette page n'existe pas. Retournez à l'accueil pour découvrir Atlas Pro ONTV, le N°1 IPTV France."
  canonical="https://atlasproontv.fr/404"
>
  <AnnouncementBar />
  <Navbar />

  <main style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg,#0C0C12);position:relative;overflow:hidden;">

    <!-- Background glow -->
    <div style="position:absolute;width:600px;height:400px;background:radial-gradient(ellipse,rgba(232,25,44,0.08) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;border-radius:50%;"></div>
    <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(232,25,44,.015) 1px,transparent 1px),linear-gradient(90deg,rgba(232,25,44,.015) 1px,transparent 1px);background-size:64px 64px;pointer-events:none;"></div>

    <div style="text-align:center;padding:2rem 1.5rem;position:relative;z-index:1;max-width:560px;">

      <!-- 404 number -->
      <div style="font-family:'Outfit',sans-serif;font-size:clamp(6rem,20vw,10rem);font-weight:900;line-height:1;color:var(--accent,#E8192C);opacity:0.15;user-select:none;margin-bottom:-1rem;">404</div>

      <!-- Icon -->
      <div style="width:72px;height:72px;background:rgba(232,25,44,0.08);border:1px solid rgba(232,25,44,0.2);border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#E8192C" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>

      <h1 style="font-family:'Outfit',sans-serif;font-size:clamp(1.75rem,4vw,2.25rem);font-weight:900;color:#fff;margin-bottom:0.75rem;line-height:1.2;">
        Page introuvable
      </h1>
      <p style="font-family:'Barlow',sans-serif;font-size:1rem;color:var(--text-muted,#8899aa);line-height:1.75;margin-bottom:2rem;">
        La page que vous recherchez n'existe pas ou a été déplacée. Retournez à l'accueil pour découvrir nos offres IPTV.
      </p>

      <!-- Actions -->
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a
          href="/"
          style="display:inline-flex;align-items:center;gap:8px;padding:13px 28px;background:var(--accent,#E8192C);color:white;font-family:'Outfit',sans-serif;font-weight:700;font-size:0.9rem;border-radius:8px;text-decoration:none;"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>
          Retour à l'accueil
        </a>
        <a
          href="/#abonnement"
          style="display:inline-flex;align-items:center;gap:8px;padding:13px 28px;background:transparent;color:#fff;font-family:'Outfit',sans-serif;font-weight:600;font-size:0.9rem;border:1px solid rgba(255,255,255,0.15);border-radius:8px;text-decoration:none;"
        >
          Voir les offres →
        </a>
      </div>

      <!-- Quick links -->
      <div style="margin-top:3rem;display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:center;">
        {[
          { label: 'Chaînes TV', href: '/#chaines' },
          { label: 'Téléchargement', href: '/#telecharger' },
          { label: 'FAQ', href: '/#faq' },
          { label: 'Blog', href: '/blog' },
          { label: 'Contact', href: '/#contact' },
        ].map(link => (
          <a
            href={link.href}
            style="padding:6px 16px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:20px;font-family:'Outfit',sans-serif;font-size:0.78rem;font-weight:600;color:var(--text-muted,#8899aa);text-decoration:none;transition:all .2s;"
            onmouseover="this.style.borderColor='rgba(232,25,44,0.3)';this.style.color='var(--accent,#E8192C)'"
            onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.color='var(--text-muted,#8899aa)'"
          >
            {link.label}
          </a>
        ))}
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

---
---
<section id="accueil" style="position:relative;min-height:100vh;display:flex;align-items:flex-end;overflow:hidden;background:var(--bg);">

  <!-- Background image layer -->
  <div style="position:absolute;inset:0;">
    <img
      src="/banner-premium-iptv.jpeg"
      alt=""
      aria-hidden="true"
      loading="eager"
      fetchpriority="high"
      style="width:100%;height:100%;object-fit:cover;object-position:center top;opacity:0.35;filter:saturate(1.2);"
    />
    <!-- Dark overlay gradient -->
    <div style="position:absolute;inset:0;background:linear-gradient(to right, rgba(12,12,18,1) 0%, rgba(12,12,18,0.85) 40%, rgba(12,12,18,0.4) 70%, rgba(12,12,18,0.2) 100%);"></div>
    <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(12,12,18,1) 0%, rgba(12,12,18,0.7) 35%, transparent 70%);"></div>
  </div>

  <!-- Red atmospheric glow (right side) -->
  <div style="position:absolute;width:700px;height:700px;background:radial-gradient(circle,rgba(232,25,44,0.22) 0%,rgba(232,25,44,0.08) 40%,transparent 70%);border-radius:50%;right:-100px;top:50%;transform:translateY(-50%);pointer-events:none;animation:glow-pulse 4s ease-in-out infinite;"></div>
  <div style="position:absolute;width:400px;height:400px;background:radial-gradient(circle,rgba(232,25,44,0.12) 0%,transparent 70%);border-radius:50%;left:20%;bottom:-100px;pointer-events:none;"></div>

  <!-- Particles -->
  <div style="position:absolute;inset:0;pointer-events:none;overflow:hidden;">
    <div class="particle" style="width:2px;height:2px;background:#E8192C;left:12%;animation-duration:12s;animation-delay:0s;"></div>
    <div class="particle" style="width:1.5px;height:1.5px;background:#FFC107;left:28%;animation-duration:16s;animation-delay:4s;"></div>
    <div class="particle" style="width:2px;height:2px;background:#E8192C;left:55%;animation-duration:10s;animation-delay:2s;"></div>
    <div class="particle" style="width:1px;height:1px;background:#fff;left:72%;animation-duration:14s;animation-delay:7s;"></div>
    <div class="particle" style="width:1.5px;height:1.5px;background:#E8192C;left:85%;animation-duration:11s;animation-delay:3s;"></div>
  </div>

  <!-- Content -->
  <div style="max-width:1200px;margin:0 auto;padding:6rem 2rem 5rem;width:100%;position:relative;z-index:1;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:flex-end;" class="hero-grid">

      <!-- Left Content -->
      <div>
        <!-- Category label -->
        <div style="display:inline-flex;align-items:center;gap:8px;margin-bottom:1.5rem;animation:fadeInUp 0.5s ease both;">
          <span style="font-family:'Outfit',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-muted);">N°1 ABONNEMENT IPTV EN FRANCE</span>
        </div>

        <!-- Main Title -->
        <h1 style="font-family:'Outfit',sans-serif;font-weight:900;font-size:clamp(3rem,6vw,5.5rem);line-height:1.0;color:#FFFFFF;margin-bottom:1.25rem;letter-spacing:-0.02em;animation:fadeInUp 0.6s 0.1s ease both;">
          Atlas Pro<br/>
          <span style="color:var(--accent);">ONTV</span>
        </h1>

        <!-- Rating row -->
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:1.5rem;animation:fadeInUp 0.6s 0.2s ease both;">
          <span style="font-family:'Outfit',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);">NOTE CLIENTS</span>
          <div class="stars" style="font-size:0.85rem;letter-spacing:2px;">★★★★★</div>
          <span style="font-family:'Outfit',sans-serif;font-size:0.85rem;font-weight:700;color:var(--gold);">4.8</span>
          <span style="width:4px;height:4px;background:var(--text-muted);border-radius:50%;"></span>
          <span style="font-family:'Outfit',sans-serif;font-size:0.82rem;color:var(--text-muted);">Sport · Cinéma · International · 2026</span>
        </div>

        <!-- Description -->
        <p style="font-family:'Barlow',sans-serif;color:var(--text-muted);font-size:1rem;line-height:1.75;margin-bottom:2.25rem;max-width:480px;animation:fadeInUp 0.6s 0.3s ease both;">
          Accédez à <strong style="color:#FFFFFF;">+15 000 chaînes HD/4K</strong> et <strong style="color:#FFFFFF;">+70 000 films & séries VOD</strong>. Compatible Firestick, Android, iOS, Smart TV, MAG et PC. Livraison instantanée.
        </p>

        <!-- CTA buttons -->
        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:12px;margin-bottom:2.5rem;animation:fadeInUp 0.6s 0.4s ease both;">
          <!-- Primary: Watch Now style -->
          <a
            href="https://wa.me/33XXXXXXXXX?text=Bonjour%2C+je+voudrais+un+test+gratuit+24h+Atlas+Pro+ONTV"
            target="_blank" rel="noopener"
            style="display:inline-flex;align-items:center;gap:10px;padding:13px 26px;background:var(--accent);color:white;font-family:'Outfit',sans-serif;font-weight:700;font-size:0.9rem;border-radius:8px;text-decoration:none;transition:all .25s ease;animation:pulse-red 2.5s ease-in-out infinite;"
            onmouseover="this.style.background='#FF2D40';this.style.transform='translateY(-2px)'"
            onmouseout="this.style.background='var(--accent)';this.style.transform='translateY(0)'"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.099 1.508 5.817L.057 23.887a.5.5 0 0 0 .556.556l6.07-1.451C8.362 23.658 10.118 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm5.53 17.12c-.272.767-1.571 1.462-2.147 1.524-.549.058-1.25.084-2.015-.124-.464-.13-1.059-.302-1.825-.631-3.21-1.387-5.3-4.626-5.462-4.839-.163-.214-1.329-1.768-1.329-3.374 0-1.604.839-2.392 1.137-2.718.271-.296.591-.37.789-.37.197 0 .394.002.566.01.182.008.426-.069.667.509.251.599.853 2.083.927 2.234.075.152.124.33.025.532-.099.2-.149.327-.296.503-.148.175-.311.392-.444.527-.148.148-.302.31-.13.607.173.297.769 1.268 1.651 2.053 1.133 1.011 2.089 1.325 2.386 1.473.297.148.47.124.643-.074.173-.198.74-.863 1.038-1.16.198-.198.397-.149.668.025.272.173 1.727.815 2.024.964.297.149.495.223.568.347.074.124.074.718-.198 1.485z"/></svg>
            Test Gratuit 24h
          </a>

          <!-- Plus / Add button -->
          <a
            href="/#abonnement"
            style="width:46px;height:46px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);border-radius:8px;display:flex;align-items:center;justify-content:center;color:white;text-decoration:none;transition:all .2s ease;font-size:1.25rem;"
            onmouseover="this.style.background='rgba(255,255,255,0.18)'"
            onmouseout="this.style.background='rgba(255,255,255,0.1)'"
            title="Voir les abonnements"
          >+</a>

          <a href="/telechargement" class="btn-ghost" style="border-radius:8px;">
            Télécharger l'app →
          </a>
        </div>

        <!-- Trust badges row -->
        <div style="display:flex;flex-wrap:wrap;gap:1.25rem;animation:fadeInUp 0.6s 0.5s ease both;">
          {[
            ['✓','Livraison < 5 min'],
            ['✓','Remboursement 30j'],
            ['✓','99.9% disponibilité'],
            ['✓','Support 24h/7j'],
          ].map(([icon, text]) => (
            <div style="display:flex;align-items:center;gap:6px;">
              <span style="font-family:'Outfit',sans-serif;font-size:0.78rem;font-weight:700;color:var(--accent);">{icon}</span>
              <span style="font-family:'Barlow',sans-serif;font-size:0.8rem;color:var(--text-muted);">{text}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Floating stat pills stacked -->
      <div class="hide-mobile float-anim" style="display:flex;flex-direction:column;gap:14px;align-items:flex-end;">

        <!-- Stat cards (filmbox-style floating badges) -->
        {[
          { num: '+15 000', label: 'Chaînes en Direct', color: '#E8192C', icon: '📺' },
          { num: '+70 000', label: 'Films & Séries VOD', color: '#FFC107', icon: '🎬' },
          { num: '99.9%',   label: 'Garantie Uptime',    color: '#22C55E', icon: '⚡' },
          { num: '50K+',    label: 'Abonnés Satisfaits', color: '#6FA0FF', icon: '⭐' },
        ].map(s => (
          <div style={`background:rgba(22,22,30,0.90);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.08);border-left:3px solid ${s.color};border-radius:12px;padding:14px 20px;display:flex;align-items:center;gap:14px;min-width:220px;`}>
            <span style="font-size:1.25rem;">{s.icon}</span>
            <div>
              <div style={`font-family:'Outfit',sans-serif;font-weight:800;font-size:1.4rem;color:${s.color};line-height:1;`}>{s.num}</div>
              <div style="font-family:'Barlow',sans-serif;font-size:0.78rem;color:var(--text-muted);margin-top:2px;">{s.label}</div>
            </div>
          </div>
        ))}

        <!-- World Cup badge -->
        <div style="background:rgba(249,115,22,0.1);border:1px solid rgba(249,115,22,0.3);border-radius:12px;padding:12px 18px;display:flex;align-items:center;gap:10px;min-width:220px;">
          <span style="font-size:1.1rem;">⚽</span>
          <div>
            <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:0.78rem;color:#F97316;">Coupe du Monde 2026</div>
            <div style="font-family:'Barlow',sans-serif;font-size:0.72rem;color:var(--text-muted);">Tous les matchs en direct</div>
          </div>
          <span style="width:7px;height:7px;background:#F97316;border-radius:50%;animation:pulse-orange 1.5s ease-in-out infinite;flex-shrink:0;margin-left:auto;"></span>
        </div>
      </div>
    </div>

    <!-- Bottom stats bar — filmbox style with pill labels -->
    <div style="margin-top:4rem;display:flex;flex-wrap:wrap;gap:1rem;justify-content:flex-start;" class="fade-in-up delay-4">
      {[
        { num: '+15 000', label: 'Chaînes', color: '#E8192C' },
        { num: '+70 000', label: 'VOD',     color: '#E8192C' },
        { num: '4K UHD',  label: 'Qualité', color: '#E8192C' },
        { num: '< 5 min', label: 'Livraison', color: '#E8192C' },
      ].map(s => (
        <div style="display:flex;flex-direction:column;align-items:center;padding:14px 28px;background:rgba(22,22,30,0.7);border:1px solid var(--border);border-radius:10px;min-width:110px;">
          <div style={`font-family:'Outfit',sans-serif;font-weight:800;font-size:1.6rem;color:white;line-height:1;`}>{s.num}</div>
          <div style={`font-family:'Outfit',sans-serif;font-size:0.72rem;font-weight:600;color:${s.color};background:${s.color}22;border-radius:20px;padding:3px 12px;margin-top:6px;letter-spacing:0.06em;`}>{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Slide dots (decorative, filmbox-style) -->
    <div style="display:flex;gap:8px;margin-top:2rem;" class="fade-in-up delay-5">
      <span style="width:24px;height:7px;background:var(--accent);border-radius:4px;display:block;"></span>
      <span style="width:7px;height:7px;background:rgba(255,255,255,0.2);border-radius:50%;display:block;"></span>
      <span style="width:7px;height:7px;background:rgba(255,255,255,0.2);border-radius:50%;display:block;"></span>
    </div>
  </div>
</section>

<style>
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('#accueil .fade-in-up').forEach(el => obs.observe(el));
</script>

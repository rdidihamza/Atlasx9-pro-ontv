---

<BaseLayout
  title="Téléchargement — Atlas Pro ONTV | Applications IPTV Android, iOS, PC, Smart TV"
  description="Téléchargez les applications Atlas Pro ONTV pour tous vos appareils : Android, Firestick, iOS, Apple TV, PC Windows, Mac, Smart TV, MAG, Kodi et plus encore."
  canonical="https://atlasproontv.fr/telechargement"
>
  <AnnouncementBar />
  <Navbar />
  <main>

    <!-- Hero -->
    <section style="position:relative;padding:8rem 0 5rem;background:var(--bg);overflow:hidden;">
      <div style="position:absolute;inset:0;pointer-events:none;">
        <div style="position:absolute;width:600px;height:600px;background:radial-gradient(circle,rgba(232,25,44,0.08) 0%,transparent 70%);border-radius:50%;right:-100px;top:-150px;"></div>
        <div style="position:absolute;width:400px;height:400px;background:radial-gradient(circle,rgba(111,160,255,0.06) 0%,transparent 70%);border-radius:50%;left:-80px;bottom:-80px;"></div>
        <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.015) 1px,transparent 1px);background-size:50px 50px;"></div>
      </div>
      <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1;text-align:center;">
        <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 16px;background:rgba(232,25,44,0.1);border:1px solid rgba(232,25,44,0.3);border-radius:30px;margin-bottom:1.75rem;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#E8192C" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <span style="font-family:'Outfit',sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#E8192C;">Téléchargement</span>
        </div>
        <h1 style="font-family:'Outfit',sans-serif;font-weight:900;font-size:clamp(2.5rem,5vw,4rem);color:#fff;line-height:1.1;margin-bottom:1.25rem;">
          Installez <span style="color:var(--accent);">Atlas Pro ONTV</span><br/>sur tous vos appareils
        </h1>
        <p style="font-family:'Barlow',sans-serif;font-size:1.05rem;color:var(--text-muted);max-width:600px;margin:0 auto 2.5rem;line-height:1.8;">
          Android · Firestick · iOS · Apple TV · PC · Mac · Smart TV · MAG · Kodi · Enigma2 et plus encore.
        </p>
        <!-- Platform quick links -->
        <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:10px;">
          {[
            ['#android','📱 Android'],
            ['#smarttv','📺 Smart TV'],
            ['#ios','🍎 iOS'],
            ['#pc','💻 PC / Mac'],
            ['#demod','📡 Démodulateurs'],
            ['#autre','🔧 Autre'],
          ].map(([href, label]) => (
            <a href={href} style="padding:8px 18px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:50px;font-family:'Outfit',sans-serif;font-size:0.8rem;font-weight:600;color:var(--text-muted);text-decoration:none;transition:all .2s;" onmouseover="this.style.borderColor='rgba(232,25,44,0.5)';this.style.color='white'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">{label}</a>
          ))}
        </div>
      </div>
    </section>

    <!-- Firestick tip -->
    <div style="background:rgba(111,160,255,0.05);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
      <div style="max-width:1200px;margin:0 auto;padding:1.1rem 1.5rem;display:flex;align-items:center;gap:12px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6FA0FF" stroke-width="2" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p style="font-family:'Barlow',sans-serif;font-size:0.88rem;color:var(--text-muted);margin:0;line-height:1.6;">
          <strong style="color:#fff;">Firestick :</strong> Activez les sources inconnues dans <strong style="color:#6FA0FF;">Paramètres → Ma Fire TV → Options développeur</strong> avant d'installer un APK.
        </p>
      </div>
    </div>

    <div style="max-width:1200px;margin:0 auto;padding:4rem 1.5rem 6rem;">

      <!-- ── Android ── -->
      <section id="android" style="margin-bottom:5rem;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:2rem;">
          <div style="width:40px;height:40px;background:rgba(34,197,94,0.12);border:1px solid rgba(34,197,94,0.3);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;">📱</div>
          <div>
            <h2 style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.3rem;color:#fff;margin:0;">Android</h2>
            <p style="font-family:'Barlow',sans-serif;font-size:0.8rem;color:var(--text-muted);margin:0;">Smartphones · Tablettes · Box Android · Firestick · Android TV</p>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;" class="dl-grid">
          {androidApps.map(app => (
            <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:1.4rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;transition:all .25s;" class="dl-card">
              <div style="display:flex;align-items:center;gap:12px;min-width:0;">
                <div style="width:40px;height:40px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.2);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;">{app.icon}</div>
                <div style="min-width:0;">
                  <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:0.88rem;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{app.name}</div>
                  {app.badge && <span style={`font-family:'Outfit',sans-serif;font-size:0.62rem;font-weight:700;color:${app.badgeColor};letter-spacing:0.06em;text-transform:uppercase;`}>{app.badge}</span>}
                </div>
              </div>
              <a
                href={app.link}
                target="_blank" rel="noopener"
                style="flex-shrink:0;display:inline-flex;align-items:center;gap:6px;padding:8px 14px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3);border-radius:8px;color:#22C55E;font-family:'Outfit',sans-serif;font-size:0.75rem;font-weight:700;text-decoration:none;transition:all .2s;white-space:nowrap;"
                onmouseover="this.style.background='rgba(34,197,94,0.2)'"
                onmouseout="this.style.background='rgba(34,197,94,0.1)'"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                {app.ext}
              </a>
            </div>
          ))}
        </div>
      </section>

      <!-- ── Smart TV ── -->
      <section id="smarttv" style="margin-bottom:5rem;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:2rem;">
          <div style="width:40px;height:40px;background:rgba(111,160,255,0.12);border:1px solid rgba(111,160,255,0.3);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;">📺</div>
          <div>
            <h2 style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.3rem;color:#fff;margin:0;">Smart TV</h2>
            <p style="font-family:'Barlow',sans-serif;font-size:0.8rem;color:var(--text-muted);margin:0;">Samsung · LG · Philips · Hisense et toutes marques</p>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;" class="dl-grid">
          {smartTvApps.map(app => (
            <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:1.4rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;transition:all .25s;" class="dl-card">
              <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:40px;height:40px;background:rgba(111,160,255,0.1);border:1px solid rgba(111,160,255,0.2);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;">{app.icon}</div>
                <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:0.88rem;color:#fff;">{app.name}</div>
              </div>
              <a
                href={app.link}
                style="flex-shrink:0;display:inline-flex;align-items:center;gap:6px;padding:8px 14px;background:rgba(111,160,255,0.1);border:1px solid rgba(111,160,255,0.3);border-radius:8px;color:#6FA0FF;font-family:'Outfit',sans-serif;font-size:0.75rem;font-weight:700;text-decoration:none;transition:all .2s;"
                onmouseover="this.style.background='rgba(111,160,255,0.2)'"
                onmouseout="this.style.background='rgba(111,160,255,0.1)'"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                {app.ext}
              </a>
            </div>
          ))}
        </div>
      </section>

      <!-- ── iOS ── -->
      <section id="ios" style="margin-bottom:5rem;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:2rem;">
          <div style="width:40px;height:40px;background:rgba(255,193,7,0.12);border:1px solid rgba(255,193,7,0.3);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;">🍎</div>
          <div>
            <h2 style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.3rem;color:#fff;margin:0;">iOS</h2>
            <p style="font-family:'Barlow',sans-serif;font-size:0.8rem;color:var(--text-muted);margin:0;">iPhones · iPad · Apple TV</p>

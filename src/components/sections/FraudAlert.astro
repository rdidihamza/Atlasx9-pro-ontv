---
---
<div style="position:relative;background:rgba(239,68,68,0.04);border-top:1px solid rgba(239,68,68,0.12);border-bottom:1px solid rgba(239,68,68,0.12);padding:0.875rem 0;z-index:10;">
  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;">
    <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;justify-content:center;">

      <!-- Warning icon -->
      <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2.5">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <span style="font-family:var(--font-sans);font-weight:700;font-size:0.78rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--red);">Alerte Fraude</span>
      </div>

      <!-- Separator -->
      <div style="width:1px;height:14px;background:rgba(239,68,68,0.2);flex-shrink:0;" class="hide-mobile"></div>

      <!-- Text -->
      <p style="font-family:var(--font-body);font-size:0.8rem;color:var(--text-muted);line-height:1.5;">
        Des sites frauduleux imitent Atlas Pro ONTV.
        <strong style="color:var(--text);">Commandez uniquement via ce site et notre WhatsApp officiel.</strong>
      </p>

      <!-- Do/Don't badges -->
      <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;flex-shrink:0;">
        <span style="padding:3px 10px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:20px;font-family:var(--font-sans);font-size:0.68rem;font-weight:700;letter-spacing:0.06em;color:var(--green);white-space:nowrap;">
          ✓ Site officiel
        </span>
        <span style="padding:3px 10px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:20px;font-family:var(--font-sans);font-size:0.68rem;font-weight:700;letter-spacing:0.06em;color:var(--green);white-space:nowrap;">
          ✓ WhatsApp uniquement
        </span>
        <span style="padding:3px 10px;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:20px;font-family:var(--font-sans);font-size:0.68rem;font-weight:700;letter-spacing:0.06em;color:#f87171;white-space:nowrap;">
          ✗ Jamais de sites inconnus
        </span>
      </div>

      <!-- Verify link -->
      <a
        href="https://wa.me/33XXXXXXXXX?text=Bonjour%2C+je+veux+vérifier+l%27authenticité+de+ce+site"
        target="_blank"
        rel="noopener"
        style="flex-shrink:0;display:inline-flex;align-items:center;gap:6px;padding:4px 12px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);border-radius:8px;color:#f87171;font-family:var(--font-sans);font-weight:700;font-size:0.72rem;text-decoration:none;white-space:nowrap;transition:all 0.2s;"
      >
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Vérifier
      </a>

    </div>
  </div>
</div>

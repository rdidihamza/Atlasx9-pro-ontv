---
---
<section id="mondial" style="position: relative; padding: 6rem 0; overflow: hidden; background: linear-gradient(180deg, #070710 0%, #050c1a 50%, #070710 100%);">
  <!-- Dramatic background elements -->
  <div style="position: absolute; inset: 0; pointer-events: none;">
    <!-- USA flag inspired gradient left -->
    <div style="position: absolute; left: 0; top: 0; bottom: 0; width: 40%; background: linear-gradient(90deg, rgba(204,0,0,0.05) 0%, transparent 100%);"></div>
    <!-- French flag inspired gradient right -->
    <div style="position: absolute; right: 0; top: 0; bottom: 0; width: 40%; background: linear-gradient(270deg, rgba(0,85,164,0.05) 0%, transparent 100%);"></div>
    <!-- Center gold glow -->
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 700px; height: 400px; background: radial-gradient(ellipse, rgba(245,158,11,0.08) 0%, transparent 70%); border-radius: 50%;"></div>
    <!-- Grid lines -->
    <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(61,155,233,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(61,155,233,0.03) 1px, transparent 1px); background-size: 60px 60px;"></div>
  </div>

  <div style="max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; position: relative; z-index: 1;">

    <!-- Header -->
    <div style="text-align: center; margin-bottom: 4rem;">
      <!-- Trophy + flags -->
      <div style="display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
        <!-- France colors -->
        <div style="display: flex; gap: 3px; border-radius: 4px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.3);">
          <div style="width: 20px; height: 30px; background: #002395;"></div>
          <div style="width: 20px; height: 30px; background: white;"></div>
          <div style="width: 20px; height: 30px; background: #ED2939;"></div>
        </div>

        <!-- Trophy SVG -->
        <div style="position: relative;">
          <div style="position: absolute; inset: -10px; background: radial-gradient(circle, rgba(245,158,11,0.3) 0%, transparent 70%); border-radius: 50%;"></div>
          <svg width="70" height="70" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="bounce-gentle">
            <!-- Trophy cup -->
            <path d="M35 15 H65 V55 C65 68 55 75 50 75 C45 75 35 68 35 55 Z" fill="url(#trophyGold)" stroke="#d97706" stroke-width="1.5"/>
            <!-- Trophy handles -->
            <path d="M35 25 C25 25 20 32 20 38 C20 44 25 48 35 45" stroke="#f59e0b" stroke-width="3" fill="none" stroke-linecap="round"/>
            <path d="M65 25 C75 25 80 32 80 38 C80 44 75 48 65 45" stroke="#f59e0b" stroke-width="3" fill="none" stroke-linecap="round"/>
            <!-- Trophy base -->
            <rect x="42" y="75" width="16" height="8" rx="2" fill="#d97706"/>
            <rect x="35" y="83" width="30" height="5" rx="2" fill="#b45309"/>
            <!-- Star -->
            <path d="M50 28 L52 34 L58 34 L53 38 L55 44 L50 40 L45 44 L47 38 L42 34 L48 34 Z" fill="#fde68a" opacity="0.9"/>
            <defs>
              <linearGradient id="trophyGold" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#fde68a"/>
                <stop offset="50%" style="stop-color:#f59e0b"/>
                <stop offset="100%" style="stop-color:#d97706"/>
              </linearGradient>
            </defs>
          </svg>
        </div>

        <!-- USA colors -->
        <div style="display: flex; flex-direction: column; gap: 2px; border-radius: 4px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.3);">
          <div style="width: 30px; height: 8px; background: #B22234;"></div>
          <div style="width: 30px; height: 8px; background: white;"></div>
          <div style="width: 30px; height: 8px; background: #B22234;"></div>
          <div style="width: 30px; height: 8px; background: white;"></div>
        </div>
      </div>

      <!-- World Cup Live badge -->
      <div style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.4); border-radius: 30px; margin-bottom: 1.5rem;">
        <span style="width: 8px; height: 8px; background: #ef4444; border-radius: 50%; animation: pulse-glow 1.5s ease-in-out infinite;"></span>
        <span style="color: #ef4444; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase;">Diffusion EN DIRECT</span>
      </div>

      <h2 style="font-family: 'Poppins', sans-serif; font-weight: 900; font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.2; margin-bottom: 1.25rem; color: #f1f5f9;">
        🏆 Coupe du Monde 2026
        <br />
        <span class="worldcup-text">Regardez TOUS les Matchs</span>
        <br />
        <span style="color: #f1f5f9;">en Direct</span>
      </h2>

      <p style="color: #94a3b8; font-size: 1.15rem; max-width: 680px; margin: 0 auto 2rem; line-height: 1.8;">
        Du <strong style="color: #f1f5f9;">11 juin au 19 juillet 2026</strong> aux États-Unis — Ne ratez aucune seconde du Mondial ! Tous les matchs diffusés en <strong style="color: #f59e0b;">HD et 4K</strong> avec Atlas Pro ONTV.
      </p>

      <!-- Countdown-style stats -->
      <div style="display: inline-flex; flex-wrap: wrap; gap: 0; border: 1px solid rgba(245,158,11,0.3); border-radius: 12px; overflow: hidden; margin-bottom: 1rem;">
        <div style="padding: 16px 28px; border-right: 1px solid rgba(245,158,11,0.3); text-align: center;">
          <div style="font-family: 'Poppins', sans-serif; font-size: 2rem; font-weight: 900; color: #f59e0b; line-height: 1;">64</div>
          <div style="color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;">Matchs</div>
        </div>
        <div style="padding: 16px 28px; border-right: 1px solid rgba(245,158,11,0.3); text-align: center;">
          <div style="font-family: 'Poppins', sans-serif; font-size: 2rem; font-weight: 900; color: #f59e0b; line-height: 1;">48</div>
          <div style="color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;">Pays</div>
        </div>
        <div style="padding: 16px 28px; border-right: 1px solid rgba(245,158,11,0.3); text-align: center;">
          <div style="font-family: 'Poppins', sans-serif; font-size: 2rem; font-weight: 900; color: #f59e0b; line-height: 1;">16</div>
          <div style="color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;">Villes USA</div>
        </div>
        <div style="padding: 16px 28px; text-align: center;">
          <div style="font-family: 'Poppins', sans-serif; font-size: 2rem; font-weight: 900; color: #22c55e; line-height: 1;">100%</div>
          <div style="color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;">Live HD</div>
        </div>
      </div>
    </div>

    <!-- World Cup Banner -->
    <div style="margin-bottom: 3rem;" class="fade-in-up">
      <img
        src="/banner-coupe-du-monde-2026.jpeg"
        alt="Coupe du Monde 2026 — USA · Mexique · Canada"
        style="width:100%;max-width:900px;display:block;margin:0 auto;border-radius:16px;border:1px solid rgba(245,158,11,0.25);box-shadow:0 20px 60px rgba(245,158,11,0.15);"
      />
    </div>

    <!-- Main content grid -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; margin-bottom: 4rem;" class="wc-grid">

      <!-- Left: Key cards -->
      <div style="display: flex; flex-direction: column; gap: 1.25rem;">

        <!-- Card 1: Coverage -->
        <div class="worldcup-border" style="border-radius: 16px; padding: 1.5rem;">
          <div style="display: flex; align-items: flex-start; gap: 1rem;">
            <div style="width: 48px; height: 48px; background: rgba(204,0,0,0.15); border: 1px solid rgba(204,0,0,0.3); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div>
              <h3 style="font-family: 'Poppins', sans-serif; font-weight: 700; color: #f1f5f9; margin-bottom: 0.5rem; font-size: 1rem;">Couverture Complète</h3>
              <p style="color: #64748b; font-size: 0.875rem; line-height: 1.6;">Tous les 64 matchs diffusés en direct, du tour de groupes jusqu'à la grande finale. Faites-vous plaisir !</p>
              <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-top: 0.75rem;">
                <span style="background: rgba(61,155,233,0.1); border: 1px solid rgba(61,155,233,0.2); color: #3D9BE9; padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600;">Phase de Groupes</span>
                <span style="background: rgba(61,155,233,0.1); border: 1px solid rgba(61,155,233,0.2); color: #3D9BE9; padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600;">Huitièmes</span>
                <span style="background: rgba(61,155,233,0.1); border: 1px solid rgba(61,155,233,0.2); color: #3D9BE9; padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600;">Quarts</span>
                <span style="background: rgba(61,155,233,0.1); border: 1px solid rgba(61,155,233,0.2); color: #3D9BE9; padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600;">Demis</span>
                <span style="background: rgba(245,158,11,0.15); border: 1px solid rgba(245,158,11,0.3); color: #f59e0b; padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600;">FINALE</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 2: Channels -->
        <div style="background: rgba(15,15,26,0.8); border: 1px solid #1e293b; border-radius: 16px; padding: 1.5rem;">
          <div style="display: flex; align-items: flex-start; gap: 1rem;">
            <div style="width: 48px; height: 48px; background: rgba(61,155,233,0.1); border: 1px solid rgba(61,155,233,0.2); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3D9BE9" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
            <div>
              <h3 style="font-family: 'Poppins', sans-serif; font-weight: 700; color: #f1f5f9; margin-bottom: 0.5rem; font-size: 1rem;">Toutes les Chaînes Diffuseurs</h3>
              <p style="color: #64748b; font-size: 0.875rem; line-height: 1.6; margin-bottom: 0.75rem;">Accédez à tous les diffuseurs officiels mondiaux de la Coupe du Monde 2026.</p>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px;">
                <div style="display: flex; align-items: center; gap: 6px; color: #94a3b8; font-size: 0.8rem;">
                  <div style="width: 6px; height: 6px; background: #f97316; border-radius: 50%;"></div> beIN Sports HD
                </div>
                <div style="display: flex; align-items: center; gap: 6px; color: #94a3b8; font-size: 0.8rem;">
                  <div style="width: 6px; height: 6px; background: #f97316; border-radius: 50%;"></div> RMC Sport
                </div>
                <div style="display: flex; align-items: center; gap: 6px; color: #94a3b8; font-size: 0.8rem;">
                  <div style="width: 6px; height: 6px; background: #3D9BE9; border-radius: 50%;"></div> TF1 HD
                </div>
                <div style="display: flex; align-items: center; gap: 6px; color: #94a3b8; font-size: 0.8rem;">
                  <div style="width: 6px; height: 6px; background: #3D9BE9; border-radius: 50%;"></div> Fox Sports USA
                </div>
                <div style="display: flex; align-items: center; gap: 6px; color: #94a3b8; font-size: 0.8rem;">
                  <div style="width: 6px; height: 6px; background: #22c55e; border-radius: 50%;"></div> ITV HD (UK)
                </div>
                <div style="display: flex; align-items: center; gap: 6px; color: #94a3b8; font-size: 0.8rem;">
                  <div style="width: 6px; height: 6px; background: #22c55e; border-radius: 50%;"></div> ESPN
                </div>
                <div style="display: flex; align-items: center; gap: 6px; color: #94a3b8; font-size: 0.8rem;">
                  <div style="width: 6px; height: 6px; background: #f59e0b; border-radius: 50%;"></div> Telemundo
                </div>
                <div style="display: flex; align-items: center; gap: 6px; color: #94a3b8; font-size: 0.8rem;">
                  <div style="width: 6px; height: 6px; background: #f59e0b; border-radius: 50%;"></div> Sky Sports
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 3: Quality -->
        <div style="background: rgba(15,15,26,0.8); border: 1px solid #1e293b; border-radius: 16px; padding: 1.5rem;">
          <div style="display: flex; align-items: flex-start; gap: 1rem;">
            <div style="width: 48px; height: 48px; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            </div>
            <div>
              <h3 style="font-family: 'Poppins', sans-serif; font-weight: 700; color: #f1f5f9; margin-bottom: 0.5rem; font-size: 1rem;">Qualité d'Image Exceptionnelle</h3>
              <p style="color: #64748b; font-size: 0.875rem; line-height: 1.6;">Profitez de la meilleure expérience de visionnage possible pour chaque match.</p>
              <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 0.75rem;">
                <div style="text-align: center; background: rgba(61,155,233,0.1); border: 1px solid rgba(61,155,233,0.2); padding: 8px 12px; border-radius: 8px;">
                  <div style="font-family: 'Poppins', sans-serif; font-weight: 800; color: #3D9BE9; font-size: 0.9rem;">4K</div>
                  <div style="color: #64748b; font-size: 0.65rem;">UHD</div>
                </div>
                <div style="text-align: center; background: rgba(61,155,233,0.1); border: 1px solid rgba(61,155,233,0.2); padding: 8px 12px; border-radius: 8px;">
                  <div style="font-family: 'Poppins', sans-serif; font-weight: 800; color: #3D9BE9; font-size: 0.9rem;">FHD</div>
                  <div style="color: #64748b; font-size: 0.65rem;">1080p</div>
                </div>
                <div style="text-align: center; background: rgba(61,155,233,0.1); border: 1px solid rgba(61,155,233,0.2); padding: 8px 12px; border-radius: 8px;">
                  <div style="font-family: 'Poppins', sans-serif; font-weight: 800; color: #3D9BE9; font-size: 0.9rem;">HD</div>
                  <div style="color: #64748b; font-size: 0.65rem;">720p</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Large visual -->
      <div style="position: relative;">
        <!-- Main visual box -->
        <div style="background: linear-gradient(135deg, rgba(10,12,30,0.9), rgba(5,12,26,0.9)); border: 1px solid rgba(245,158,11,0.2); border-radius: 24px; padding: 2.5rem; position: relative; overflow: hidden;">
          <!-- Glow -->
          <div style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(245,158,11,0.15) 0%, transparent 70%); border-radius: 50%;"></div>
          <div style="position: absolute; bottom: -50px; left: -50px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(61,155,233,0.1) 0%, transparent 70%); border-radius: 50%;"></div>

          <!-- Football field SVG -->
          <svg viewBox="0 0 400 260" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 100%; height: auto; margin-bottom: 1.5rem;">
            <!-- Field -->
            <rect width="400" height="260" rx="12" fill="#1a2e1a"/>
            <rect x="5" y="5" width="390" height="250" rx="10" fill="#1f3a1f"/>
            <!-- Field lines -->
            <rect x="15" y="15" width="370" height="230" rx="2" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
            <line x1="200" y1="15" x2="200" y2="245" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
            <circle cx="200" cy="130" r="35" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
            <circle cx="200" cy="130" r="4" fill="rgba(255,255,255,0.6)"/>
            <!-- Penalty boxes -->
            <rect x="15" y="75" width="75" height="110" rx="2" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            <rect x="310" y="75" width="75" height="110" rx="2" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            <rect x="15" y="100" width="40" height="60" rx="2" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
            <rect x="345" y="100" width="40" height="60" rx="2" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
            <!-- Goals -->
            <rect x="0" y="110" width="15" height="40" rx="2" fill="none" stroke="white" stroke-width="2" opacity="0.5"/>
            <rect x="385" y="110" width="15" height="40" rx="2" fill="none" stroke="white" stroke-width="2" opacity="0.5"/>
            <!-- Ball -->
            <circle cx="200" cy="130" r="10" fill="white" opacity="0.9"/>
            <path d="M195 125 L200 122 L205 125 L204 131 L196 131 Z" fill="#333" opacity="0.7"/>
            <!-- Players (dots with jersey numbers) -->
            <circle cx="80" cy="130" r="8" fill="#002395" stroke="white" stroke-width="1"/>
            <text x="80" y="134" fill="white" font-size="7" text-anchor="middle" font-weight="bold">9</text>
            <circle cx="130" cy="90" r="8" fill="#002395" stroke="white" stroke-width="1"/>
            <text x="130" y="94" fill="white" font-size="7" text-anchor="middle" font-weight="bold">7</text>
            <circle cx="130" cy="170" r="8" fill="#002395" stroke="white" stroke-width="1"/>
            <text x="130" y="174" fill="white" font-size="7" text-anchor="middle" font-weight="bold">11</text>
            <circle cx="170" cy="130" r="8" fill="#002395" stroke="white" stroke-width="1"/>
            <text x="170" y="134" fill="white" font-size="7" text-anchor="middle" font-weight="bold">10</text>
            <circle cx="320" cy="130" r="8" fill="#B22234" stroke="white" stroke-width="1"/>
            <text x="320" y="134" fill="white" font-size="7" text-anchor="middle" font-weight="bold">9</text>
            <circle cx="270" cy="90" r="8" fill="#B22234" stroke="white" stroke-width="1"/>
            <text x="270" y="94" fill="white" font-size="7" text-anchor="middle" font-weight="bold">7</text>
            <!-- Score overlay -->
            <rect x="140" y="15" width="120" height="40" rx="6" fill="rgba(0,0,0,0.85)"/>
            <text x="165" y="31" fill="white" font-size="9" font-weight="bold" font-family="Poppins,sans-serif">FRANCE</text>
            <text x="260" y="31" fill="white" font-size="9" font-weight="bold" font-family="Poppins,sans-serif" text-anchor="end">USA</text>
            <text x="186" y="47" fill="#f59e0b" font-size="12" font-weight="900" font-family="Poppins,sans-serif">2</text>
            <text x="198" y="47" fill="white" font-size="10" font-family="Poppins,sans-serif">-</text>
            <text x="214" y="47" fill="#f59e0b" font-size="12" font-weight="900" font-family="Poppins,sans-serif">1</text>
            <!-- Live badge -->
            <rect x="157" y="52" width="86" height="14" rx="7" fill="rgba(239,68,68,0.3)" stroke="rgba(239,68,68,0.5)" stroke-width="1"/>
            <circle cx="166" cy="59" r="4" fill="#ef4444"/>
            <text x="200" y="63" fill="#ef4444" font-size="7.5" font-weight="700" font-family="Poppins,sans-serif" text-anchor="middle">EN DIRECT</text>
            <!-- Timer -->
            <text x="370" y="30" fill="#22c55e" font-size="10" font-weight="700" font-family="Poppins,sans-serif" text-anchor="middle">67'</text>
          </svg>

          <!-- Channels available -->
          <div>
            <p style="color: #64748b; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.75rem; font-weight: 600;">Disponible sur :</p>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
              <span style="background: rgba(249,115,22,0.15); border: 1px solid rgba(249,115,22,0.3); color: #f97316; padding: 5px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700;">beIN Sports</span>
              <span style="background: rgba(249,115,22,0.15); border: 1px solid rgba(249,115,22,0.3); color: #f97316; padding: 5px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700;">RMC Sport</span>
              <span style="background: rgba(61,155,233,0.15); border: 1px solid rgba(61,155,233,0.3); color: #3D9BE9; padding: 5px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700;">TF1 HD</span>
              <span style="background: rgba(61,155,233,0.15); border: 1px solid rgba(61,155,233,0.3); color: #3D9BE9; padding: 5px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700;">Fox Sports</span>
              <span style="background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); color: #22c55e; padding: 5px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700;">ESPN</span>

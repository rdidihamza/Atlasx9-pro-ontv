---

<!-- ─── Left Sidebar ─────────────────────────────────────── -->
<aside class="sidebar hide-mobile">
  <!-- Logo mark -->
  <a href="/" style="display:flex;align-items:center;justify-content:center;width:42px;height:42px;background:var(--accent);border-radius:10px;margin-bottom:1.25rem;flex-shrink:0;text-decoration:none;">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <rect x="2" y="3" width="20" height="14" rx="2" fill="white" fill-opacity="0.9"/>
      <circle cx="12" cy="10" r="3" fill="#E8192C"/>
      <path d="M8 21h8M12 17v4" stroke="white" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </a>

  <!-- Nav icons -->
  <a href="/" class="sidebar-icon active" title="Accueil">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>
  </a>

  <a href="/chaines" class="sidebar-icon" title="Chaînes TV">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
  </a>

  <a href="/films-series" class="sidebar-icon" title="Films & Séries">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="2" width="20" height="20" rx="2"/><path d="M7 2v20M17 2v20M2 12h20M2 7h5M17 7h5M2 17h5M17 17h5"/></svg>
  </a>

  <a href="/abonnements" class="sidebar-icon" title="Abonnements">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
  </a>

  <a href="/avis" class="sidebar-icon" title="Avis clients">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
  </a>

  <a href="/installation" class="sidebar-icon" title="Installation">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
  </a>

  <a href="/blog" class="sidebar-icon" title="Blog">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10,9 9,9 8,9"/></svg>
  </a>

  <a href="/#faq" class="sidebar-icon" title="FAQ">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
  </a>

  <!-- Spacer -->
  <div style="flex:1;"></div>

  <!-- WhatsApp -->
  <a
    href="https://wa.me/33XXXXXXXXX?text=Bonjour%2C+je+voudrais+tester+Atlas+Pro+ONTV+24h"
    target="_blank" rel="noopener"
    class="sidebar-icon"
    title="WhatsApp Support"
    style="color:#22C55E;margin-bottom:0.5rem;"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.099 1.508 5.817L.057 23.887a.5.5 0 0 0 .556.556l6.07-1.451C8.362 23.658 10.118 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm5.53 17.12c-.272.767-1.571 1.462-2.147 1.524-.549.058-1.25.084-2.015-.124-.464-.13-1.059-.302-1.825-.631-3.21-1.387-5.3-4.626-5.462-4.839-.163-.214-1.329-1.768-1.329-3.374 0-1.604.839-2.392 1.137-2.718.271-.296.591-.37.789-.37.197 0 .394.002.566.01.182.008.426-.069.667.509.251.599.853 2.083.927 2.234.075.152.124.33.025.532-.099.2-.149.327-.296.503-.148.175-.311.392-.444.527-.148.148-.302.31-.13.607.173.297.769 1.268 1.651 2.053 1.133 1.011 2.089 1.325 2.386 1.473.297.148.47.124.643-.074.173-.198.74-.863 1.038-1.16.198-.198.397-.149.668.025.272.173 1.727.815 2.024.964.297.149.495.223.568.347.074.124.074.718-.198 1.485z"/></svg>
  </a>
</aside>

<!-- ─── Top Navbar ─────────────────────────────────────────── -->
<nav id="navbar" class="topbar">

  <!-- Mobile logo (visible on mobile only) -->
  <a href="/" class="desktop-hide-flex" style="display:flex;align-items:center;gap:10px;text-decoration:none;margin-right:auto;">
    <div style="width:34px;height:34px;background:var(--accent);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" fill="white" fill-opacity="0.9"/><circle cx="12" cy="10" r="3" fill="#E8192C"/></svg>
    </div>
    <span style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1rem;color:white;">Atlas Pro <span style="color:var(--accent);">ONTV</span></span>
  </a>

  <!-- Desktop Nav links -->
  <div class="desktop-nav" style="display:none;align-items:center;gap:2rem;">
    {[
      ['/','Accueil'],
      ['/abonnements','Abonnements'],
      ['/chaines','Chaînes TV'],
      ['/films-series','Films & Séries'],
      ['/installation','Installation'],
      ['/avis','Avis'],
      ['/blog','Blog'],
    ].map(([href, label]) => (
      <a
        href={href}
        style="font-family:'Outfit',sans-serif;font-size:0.85rem;font-weight:600;color:var(--text-muted);text-decoration:none;letter-spacing:0.02em;transition:color .2s;"
        onmouseover="this.style.color='#fff'"
        onmouseout="this.style.color='var(--text-muted)'"
      >{label}</a>
    ))}
  </div>


<!-- Right side CTAs -->
  <div style="margin-left:auto;display:flex;align-items:center;gap:10px;">

    <!-- Search icon -->
    <button style="width:36px;height:36px;background:rgba(255,255,255,0.07);border:1px solid var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text-muted);transition:all .2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='var(--text-muted)'" aria-label="Recherche">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </button>

    <!-- CTA button -->
    <a
      href="https://wa.me/33XXXXXXXXX?text=Bonjour%2C+je+voudrais+tester+Atlas+Pro+ONTV+24h"
      target="_blank" rel="noopener"
      class="btn-primary hide-mobile"
      style="padding:9px 18px;font-size:0.8rem;border-radius:8px;"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.099 1.508 5.817L.057 23.887a.5.5 0 0 0 .556.556l6.07-1.451C8.362 23.658 10.118 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm5.53 17.12c-.272.767-1.571 1.462-2.147 1.524-.549.058-1.25.084-2.015-.124-.464-.13-1.059-.302-1.825-.631-3.21-1.387-5.3-4.626-5.462-4.839-.163-.214-1.329-1.768-1.329-3.374 0-1.604.839-2.392 1.137-2.718.271-.296.591-.37.789-.37.197 0 .394.002.566.01.182.008.426-.069.667.509.251.599.853 2.083.927 2.234.075.152.124.33.025.532-.099.2-.149.327-.296.503-.148.175-.311.392-.444.527-.148.148-.302.31-.13.607.173.297.769 1.268 1.651 2.053 1.133 1.011 2.089 1.325 2.386 1.473.297.148.47.124.643-.074.173-.198.74-.863 1.038-1.16.198-.198.397-.149.668.025.272.173 1.727.815 2.024.964.297.149.495.223.568.347.074.124.074.718-.198 1.485z"/></svg>
      Test Gratuit 24h
    </a>

    <!-- Mobile Hamburger -->
    <label for="mobile-toggle" class="mobile-hamburger" style="display:flex;flex-direction:column;gap:5px;cursor:pointer;padding:6px;" aria-label="Menu">
      <input type="checkbox" id="mobile-toggle" style="display:none;" />
      <span style="width:22px;height:1.5px;background:#fff;border-radius:2px;display:block;transition:all .3s;"></span>
      <span style="width:16px;height:1.5px;background:var(--text-muted);border-radius:2px;display:block;transition:all .3s;"></span>
      <span style="width:22px;height:1.5px;background:#fff;border-radius:2px;display:block;transition:all .3s;"></span>
    </label>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" style="display:none;flex-direction:column;padding:1.5rem 1.5rem;background:rgba(9,9,14,.99);backdrop-filter:blur(24px);border-bottom:1px solid var(--border);position:fixed;top:var(--header-total);left:0;right:0;z-index:99;">
  {[
    ['/','Accueil'],
    ['/abonnements','Abonnements'],
    ['/chaines','Chaînes TV'],
    ['/films-series','Films & Séries'],
    ['/installation','Installation'],
    ['/avis','Avis'],
    ['/blog','Blog'],
    ['/#contact','Contact'],
  ].map(([href, label]) => (
    <a href={href} style="color:#fff;text-decoration:none;padding:14px 0;font-family:'Outfit',sans-serif;font-weight:600;font-size:0.95rem;border-bottom:1px solid var(--border);">{label}</a>
  ))}
  <a
    href="https://wa.me/33XXXXXXXXX?text=Bonjour%2C+je+voudrais+tester+Atlas+Pro+ONTV+24h"
    target="_blank" rel="noopener"
    style="margin-top:1.25rem;display:flex;align-items:center;justify-content:center;gap:8px;padding:14px;background:var(--accent);color:white;font-family:'Outfit',sans-serif;font-weight:700;border-radius:10px;text-decoration:none;font-size:0.9rem;"
  >
    Test Gratuit 24h
  </a>
</div>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) navbar?.classList.add('navbar-scrolled');
    else navbar?.classList.remove('navbar-scrolled');
  });

  const toggle = document.getElementById('mobile-toggle') as HTMLInputElement;
  const mobileMenu = document.querySelector('.mobile-menu') as HTMLElement;
  if (toggle && mobileMenu) {
    toggle.addEventListener('change', () => {
      mobileMenu.style.display = toggle.checked ? 'flex' : 'none';
    });
  }
  document.querySelectorAll('.mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      if (toggle) toggle.checked = false;
      if (mobileMenu) mobileMenu.style.display = 'none';
    });
  });

  // Sidebar active state based on current page path
  const sidebarIcons = document.querySelectorAll<HTMLAnchorElement>('.sidebar-icon');
  const currentPath = window.location.pathname;

  sidebarIcons.forEach(icon => {
    const href = icon.getAttribute('href') || '';
    // Exact match for home, starts-with for other pages
    const isActive = href === '/' ? currentPath === '/' : (href !== '/#faq' && currentPath.startsWith(href));
    icon.classList.toggle('active', isActive);
  });

  // Scroll-based active for hash links on home page
  if (currentPath === '/') {
    const sections = document.querySelectorAll<HTMLElement>('section[id]');

    function updateActive() {
      const scrollY = window.scrollY;
      const winH = window.innerHeight;
      let current = '';

      sections.forEach(sec => {
        const top = sec.offsetTop - winH * 0.4;
        if (scrollY >= top) current = sec.id;
      });

      sidebarIcons.forEach(icon => {
        const href = icon.getAttribute('href') || '';
        if (href.startsWith('/#')) {
          const isActive = current ? href.includes(`#${current}`) : href === '/';
          icon.classList.toggle('active', isActive);
        }
      });
    }

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => { updateActive(); ticking = false; });
        ticking = true;
      }
    }, { passive: true });

    updateActive();
  }
</script>

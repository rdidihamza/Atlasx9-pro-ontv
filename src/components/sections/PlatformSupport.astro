    guide: "1. App Store > 'Downloader'\n2. Code 9380782 (IBO recommandé)\n3. Sources inconnues: Paramètres > Ma Fire TV\n4. Installez & profitez",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="2" y="7" width="20" height="10" rx="5" fill="#f97316" opacity="0.9"/>
